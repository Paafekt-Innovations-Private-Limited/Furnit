// FAQ - AI Features (added)
"faq.aiFeatures" = "Funciones de IA";
"faq.whatIsBrainIcon" = "¿Qué hace el icono del cerebro?";
"faq.whatIsBrainIconAnswer" = "El icono del cerebro activa SmartyPants - una función de detección de objetos impulsada por IA. Usa tu cámara para identificar muebles y objetos en tiempo real, mostrando etiquetas y cuadros delimitadores alrededor de los elementos detectados.";
"faq.howToScreenshot" = "¿Cómo tomo una captura de pantalla?";
"faq.howToScreenshotAnswer" = "Cuando SmartyPants está activo (icono del cerebro verde), aparece un icono de compartir en la parte inferior derecha. Tócalo para guardar una captura de pantalla con las detecciones de IA en tu biblioteca de fotos.";
"faq.howToSaveRoom" = "¿Cómo guardo una habitación?";
"faq.howToSaveRoomAnswer" = "Después de generar una habitación 3D, toca el icono de guardar (flecha de descarga) en la barra de herramientas para guardarla con un nombre personalizado. Las habitaciones no guardadas se eliminarán al tocar Atrás.";

// FAQ - 3D Room Controls (added)
"faq.roomControls" = "Controles de Habitación 3D";
"faq.howToNavigate" = "¿Cómo navego dentro de la habitación?";
"faq.howToNavigateAnswer" = "Usa el joystick en la parte inferior central de la pantalla para moverte. Arrástralo en cualquier dirección para volar por la habitación. Usa el botón de recentrar (icono del visor) para restablecer la posición de la cámara.";
"faq.whatIsMemoryDisplay" = "¿Qué significa el número MB?";
"faq.whatIsMemoryDisplayAnswer" = "El MB (megabytes) mostrado en las habitaciones indica el tamaño del archivo. Esto te ayuda a administrar el almacenamiento. El almacenamiento total usado por todas las habitaciones se muestra en la parte superior de la pantalla de inicio.";


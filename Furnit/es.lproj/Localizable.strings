// FAQ - Room Creation
"faq.roomCreation" = "Creación de habitaciones";
"faq.howToCreate" = "¿Cómo creo una habitación 3D?";
"faq.howToCreateAnswer" = "Toca el icono de foto en la esquina superior izquierda de la pantalla de inicio, luego toma o selecciona una foto de tu habitación. Verás dos opciones para elegir cómo crear tu habitación 3D.";
"faq.howToTakePhoto" = "¿Cómo tomo una foto para crear una habitación?";
"faq.howToTakePhotoAnswer" = "Toca el icono de cámara en la pantalla de inicio para tomar una foto directamente. Puedes elegir entre lente Estándar (1x) o Gran Angular (0.5x ultra ancho). Mantén tu dispositivo firme y toca el botón de captura. La foto se usará para crear tu habitación 3D.";
"faq.depthAwareRoomPhoto" = "¿Ayuda tomar la foto dentro de la app?";
"faq.depthAwareRoomPhotoAnswer" = "Sí. En dispositivos compatibles, «Tomar una foto» (en lugar de la galería) usa la cámara de la app con profundidad si está disponible, lo que puede mejorar la escala y reconstrucción 3D.";
"faq.twoMethods" = "¿Cuáles son las dos opciones para crear una habitación?";
"faq.twoMethodsAnswer" = "Al elegir una foto: 1) Habitación 3D con IA – crea automáticamente una habitación realista, o 2) Configuración manual – dibujas los límites tú mismo para más control.";
"faq.whatIsAIRoom" = "¿Qué es la habitación 3D con IA?";
"faq.whatIsAIRoomAnswer" = "Convierte tu foto automáticamente en una habitación 3D que puedes recorrer. Elige una foto y la app hace el resto.";
"faq.whatIsManualRoom" = "¿Qué es la configuración manual?";
"faq.whatIsManualRoomAnswer" = "Dibujas el contorno de las paredes en la foto para controlar mejor la forma de la habitación 3D.";
"faq.whichMethodBetter" = "¿Qué método elijo?";
"faq.whichMethodBetterAnswer" = "Prueba primero la IA: es más rápida y suele funcionar bien. Si no convence, usa la configuración manual. ¡Puedes probar ambas!";
"faq.bestPhotos" = "¿Qué tipo de fotos funcionan mejor?";
"faq.bestPhotosAnswer" = "Para mejores resultados, toma fotos con buena iluminación y la cámara en horizontal. Intenta capturar toda la habitación incluyendo suelos, paredes y bordes del techo. Evita fotos borrosas u oscuras.";
"faq.generationFailing" = "¿Por qué falla la generación de mi habitación?";
"faq.generationFailingAnswer" = "La generación de habitación puede fallar si la foto es demasiado oscura, borrosa o no muestra suficientes características de la habitación. Intenta tomar una nueva foto con mejor iluminación y un ángulo más amplio.";
"faq.howManyRooms" = "¿Cuántas habitaciones puedo crear?";
"faq.howManyRoomsAnswer" = "Puedes crear hasta 1000 habitaciones. Elimina habitaciones antiguas para liberar espacio. En la parte superior verás el número de habitaciones y el almacenamiento usado.";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "Segmentación de muebles";
"faq.whatIsSegmentation" = "¿Qué es la segmentación de muebles?";
"faq.whatIsSegmentationAnswer" = "La segmentación de muebles ahora funciona desde el visor de habitación en vivo. Primero selecciona las etiquetas detectadas; luego Segmentar crea una superposición recortada solo para esos muebles seleccionados para que evalúes cómo quedan en la habitación 3D.";
"faq.howToSegment" = "¿Cómo segmento muebles de una foto?";
"faq.howToSegmentAnswer" = "En el visor de la habitación, toca el icono del cerebro, apunta la cámara al mueble, toca una o más etiquetas detectadas para seleccionarlas y luego toca Segmentar. Toca Detener para volver a las identificaciones en vivo.";
"faq.notDetected" = "¿Por qué no se detectan mis muebles?";
"faq.notDetectedAnswer" = "La detección de muebles funciona mejor con fotos claras y bien iluminadas donde los muebles son claramente visibles. Asegúrate de que los muebles no estén parcialmente ocultos o se confundan con el fondo.";
"faq.multiplePieces" = "¿Puedo segmentar múltiples muebles?";
"faq.multiplePiecesAnswer" = "¡Sí! La IA puede detectar múltiples muebles en una sola foto. Cada elemento detectado se mostrará por separado para que puedas elegir cuáles usar.";

// FAQ - 3D Room & Fitment
"faq.roomFitment" = "¿Cómo compruebo si el mueble encaja?";
"faq.roomFitmentAnswer" = "Tras añadir un mueble, redimensiónalo y muévelo en la habitación 3D para ver cómo encaja con el espacio y otros muebles.";

// FAQ - Placement intelligence & aesthetic
"faq.placementIntelligence" = "Inteligencia de colocación y estética";
"faq.whatIsPlacementIntelligence" = "¿Qué es Placement Intelligence?";
"faq.whatIsPlacementIntelligenceAnswer" = "Con SmartyPants activo en visores 3D compatibles, una tarjeta de Placement Intelligence resume si el tamaño del objeto detectado cabe en los límites de la habitación, muestra pistas de hueco en el suelo y sugerencias de esquinas cuando hay datos, e indica si la profundidad es estimada. Toca la cabecera para ver todos los detalles o déjala plegada para ahorrar espacio.";
"faq.furnitureColorAesthetic" = "¿Cómo elige la app un color para la puntuación estética?";
"faq.furnitureColorAestheticAnswer" = "La app promedia el RGB de los píxeles visibles dentro del recorte IA del mueble (la misma superposición segmentada). Ese color medio se compara con colores muestreados del suelo, paredes y techo. Si el recorte aún no está listo, se usa un color de reserva de la paleta de la habitación hasta que la segmentación aporte una muestra real.";
"faq.whatDoHarmonyContrastMean" = "¿Qué significan armonía, contraste y ajuste de estilo?";
"faq.whatDoHarmonyContrastMeanAnswer" = "Son heurísticas de diseño sencillas, no un juicio de gusto. La armonía describe cómo se relaciona el color del mueble con la paleta de la habitación (por ejemplo tonos análogos o complementarios). El contraste mide cuánto difiere el brillo respecto a suelos o paredes típicos. El ajuste de estilo compara etiquetas de estilo amplias inferidas para la habitación con un perfil moderno por defecto, así que es aproximado.";
"faq.whenDoesAestheticScoreLow" = "¿Cuándo pueden verse bajas las puntuaciones estéticas o aparecer \"clash\"?";
"faq.whenDoesAestheticScoreLowAnswer" = "Los objetos muy saturados suelen puntuar peor si su matiz no encaja con los esquemas armónicos de la app frente a tu habitación: por ejemplo verde ácido, magenta, morado o naranja de seguridad en salones cálidos beige o tostados, o primarios chillones cuando la muestra del espacio es casi monocromática. Un brillo muy parecido al suelo o la pared (marrón sobre marrón, gris sobre gris) puede bajar el contraste aunque te guste el resultado. Las habitaciones inferidas como rústicas o tradicionales pueden mostrar menos ajuste de estilo porque el perfil del mueble usa etiquetas modernas/minimal por defecto. Promedios grises o sucios con fondos cargados pueden caer en una banda \"neutral\" en lugar de clash. Las puntuaciones son solo orientativas: para decorar de verdad, confía también en tu ojo.";

"faq.howToView" = "¿Cómo veo mi habitación 3D?";
"faq.howToViewAnswer" = "Toca cualquier habitación en tu pantalla de inicio para abrir el visor 3D. Puedes rotar, hacer zoom y desplazarte por la habitación usando gestos táctiles.";
"faq.howToPlace" = "¿Cómo coloco muebles en mi habitación?";
"faq.howToPlaceAnswer" = "Después de tocar Segmentar, el mueble seleccionado aparece como una superposición en la habitación. Arrástralo para colocarlo, pellizca para cambiar el tamaño y gíralo para ajustar la orientación.";
"faq.sampleRoom" = "¿Puedo usar una habitación de ejemplo en lugar de la mía?";
"faq.sampleRoomAnswer" = "¡Sí! La aplicación proporciona habitaciones de ejemplo para experimentar. Accede a ellas desde la sección Explorar para probar la colocación de muebles sin crear primero tu propia habitación.";
"faq.accuracy" = "¿Qué tan preciso es el modelo 3D?";
"faq.accuracyAnswer" = "La habitación 3D es una estimación a partir de una sola foto. Las dimensiones pueden servir como orientación, pero no son de precisión profesional. La medición de muebles es más fiable en teléfonos con soporte de AR/profundidad.";
"faq.adjustDimensions" = "¿Puedo ajustar las dimensiones de la habitación?";
"faq.adjustDimensionsAnswer" = "No directamente en las habitaciones SHARP generadas por IA. Usa la regla en el visor para consultar el ancho, alto y fondo estimados actuales. Para mejores resultados, toma una foto clara de la habitación con esquinas visibles; las habitaciones manuales siguen los límites que tú defines.";
"faq.furnitureMeasurements" = "Muebles y medidas";
"faq.arAssistedSizing" = "¿Qué es el tamaño de muebles asistido por AR?";
"faq.arAssistedSizingAnswer" = "Primero toca el icono del cerebro, selecciona los elementos detectados y luego toca Segmentar. Usa el control de tamaño cuando quieras escala relativa a la habitación. En teléfonos con AR/profundidad, la app usa profundidad en vivo de la cámara para un tamaño de mueble más realista; sin profundidad, las medidas son aproximadas.";
"faq.measurementPill" = "¿Qué es la pequeña lectura de medidas?";
"faq.measurementPillAnswer" = "La pastilla de tamaño del mueble solo aparece cuando el modo de tamaño está activado y la app tiene una estimación de altura en vivo válida. El botón de regla muestra el ancho, alto y fondo actuales de la habitación en una tarjeta pequeña. En teléfonos sin AR, estas lecturas son menos fiables, especialmente para los muebles.";
"faq.resetOverlayScale" = "La máscara parece mal ampliada — ¿qué hago?";
"faq.resetOverlayScaleAnswer" = "Ya no hay un menú adicional. Si la superposición se ve mal, apaga y vuelve a encender el icono del cerebro, o pellizca el mueble manualmente para ajustar mejor su tamaño.";


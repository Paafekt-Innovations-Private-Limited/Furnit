// FAQ - Room Creation
"faq.roomCreation" = "إنشاء الغرفة";
"faq.howToCreate" = "كيف أنشئ غرفة ثلاثية الأبعاد؟";
"faq.howToCreateAnswer" = "Tap the photo icon in the top-left corner of the home screen, then take or select a photo of your room. You'll see two options to choose from for creating your 3D room.";
"faq.twoMethods" = "What are the two room creation options?";
"faq.twoMethodsAnswer" = "When you select a photo, you can choose between: 1) AI-Powered 3D Room - automatically creates a realistic 3D room using artificial intelligence, or 2) Manual Setup - lets you draw the room boundaries yourself for more control.";
"faq.whatIsAIRoom" = "What is AI-Powered 3D Room?";
"faq.whatIsAIRoomAnswer" = "This option uses smart technology to automatically turn your photo into a 3D room you can walk through. Just pick a photo and the app does the rest - no drawing or adjusting needed. It works like magic!";
"faq.whatIsManualRoom" = "What is Manual Setup?";
"faq.whatIsManualRoomAnswer" = "With Manual Setup, you draw the outline of your room's walls on the photo. This gives you more control over exactly how the 3D room looks. It's great when you want to fine-tune the room shape yourself.";
"faq.whichMethodBetter" = "Which method should I choose?";
"faq.whichMethodBetterAnswer" = "Try AI-Powered first - it's faster and works great for most rooms. If the result doesn't look quite right, use Manual Setup to draw the walls exactly where you want them. You can always try both and see which one you prefer!";
"faq.bestPhotos" = "ما نوع الصور التي تعمل بشكل أفضل؟";
"faq.bestPhotosAnswer" = "للحصول على أفضل النتائج، التقط الصور في إضاءة جيدة مع إمساك الجهاز بثبات. حاول التقاط الغرفة بالكامل بما في ذلك الأرضيات والجدران وحواف السقف. تجنب الصور الضبابية أو المظلمة.";
"faq.generationFailing" = "لماذا يفشل إنشاء غرفتي؟";
"faq.generationFailingAnswer" = "قد يفشل إنشاء الغرفة إذا كانت الصورة مظلمة جداً أو ضبابية أو لا تُظهر ميزات كافية للغرفة. جرب التقاط صورة جديدة بإضاءة أفضل وزاوية أوسع.";
"faq.howManyRooms" = "كم عدد الغرف التي يمكنني إنشاؤها؟";
"faq.howManyRoomsAnswer" = "يمكنك إنشاء حتى 10 غرف. احذف الغرف القديمة لإفساح المجال. يُعرض عدد الغرف في أعلى شاشتك الرئيسية.";

// FAQ - AI Features
"faq.aiFeatures" = "ميزات الذكاء الاصطناعي";
"faq.whatIsBrainIcon" = "ماذا تفعل أيقونة الدماغ؟";
"faq.whatIsBrainIconAnswer" = "تُفعّل أيقونة الدماغ ميزة SmartyPants - وهي ميزة كشف الأجسام المدعومة بالذكاء الاصطناعي. تستخدم الكاميرا لتحديد الأثاث والأجسام في الوقت الفعلي، وتعرض التسميات ومربعات الإحاطة حول العناصر المكتشفة.";
"faq.howToScreenshot" = "كيف ألتقط لقطة شاشة؟";
"faq.howToScreenshotAnswer" = "عندما يكون SmartyPants نشطاً (أيقونة الدماغ خضراء)، تظهر أيقونة المشاركة في أسفل اليمين. اضغط عليها لحفظ لقطة شاشة مع كشوفات الذكاء الاصطناعي إلى مكتبة الصور.";
"faq.howToSaveRoom" = "كيف أحفظ غرفة؟";
"faq.howToSaveRoomAnswer" = "بعد إنشاء غرفة ثلاثية الأبعاد، اضغط على أيقونة الحفظ (سهم التنزيل) في شريط الأدوات لحفظها باسم مخصص. الغرف غير المحفوظة ستُحذف عند الضغط على رجوع.";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "تجزئة الأثاث";
"faq.whatIsSegmentation" = "ما هي تجزئة الأثاث؟";
"faq.whatIsSegmentationAnswer" = "تستخدم تجزئة الأثاث الذكاء الاصطناعي لتحديد وفصل الأثاث في صورك، مما يتيح لك رؤية كيف ستتناسب كل قطعة في غرفتك ثلاثية الأبعاد.";
"faq.howToSegment" = "كيف أجزئ الأثاث من صورة؟";
"faq.howToSegmentAnswer" = "عند عرض غرفتك ثلاثية الأبعاد، اضغط على أيقونة الأثاث للوصول إلى ميزة التجزئة. اختر صورة تحتوي على أثاث، وسيقوم التطبيق تلقائياً باكتشاف واستخراج قطع الأثاث.";
"faq.notDetected" = "لماذا لم يتم اكتشاف أثاثي؟";
"faq.notDetectedAnswer" = "يعمل اكتشاف الأثاث بشكل أفضل مع الصور الواضحة والمضاءة جيداً حيث يكون الأثاث مرئياً بوضوح. تأكد من أن الأثاث غير مخفي جزئياً أو متمازج مع الخلفية.";
"faq.multiplePieces" = "هل يمكنني تجزئة قطع أثاث متعددة؟";
"faq.multiplePiecesAnswer" = "نعم! يمكن للذكاء الاصطناعي اكتشاف قطع أثاث متعددة في صورة واحدة. سيتم عرض كل قطعة مكتشفة بشكل منفصل لتختار أيها تستخدم.";

// FAQ - 3D Room Controls
"faq.roomControls" = "التحكم بالغرفة ثلاثية الأبعاد";
"faq.howToNavigate" = "كيف أتنقل داخل الغرفة؟";
"faq.howToNavigateAnswer" = "استخدم عصا التحكم في أسفل وسط الشاشة للتنقل. اسحبها في أي اتجاه للطيران عبر الغرفة. استخدم زر إعادة التمركز (أيقونة محدد المنظر) لإعادة ضبط موضع الكاميرا.";
"faq.whatIsMemoryDisplay" = "ماذا يعني رقم MB؟";
"faq.whatIsMemoryDisplayAnswer" = "يشير MB (ميجابايت) المعروض في الغرف إلى حجم الملف. يساعدك هذا على إدارة التخزين. يُعرض إجمالي التخزين المستخدم في أعلى الشاشة الرئيسية.";

// FAQ - 3D Room & Fitment
"faq.roomFitment" = "الغرفة ثلاثية الأبعاد والتركيب";
"faq.howToView" = "كيف أعرض غرفتي ثلاثية الأبعاد؟";
"faq.howToViewAnswer" = "اضغط على أي غرفة في الشاشة الرئيسية لفتح العارض ثلاثي الأبعاد. يمكنك تدوير الغرفة وتكبيرها وتحريكها باستخدام إيماءات اللمس.";
"faq.howToPlace" = "كيف أضع الأثاث في غرفتي؟";
"faq.howToPlaceAnswer" = "بعد تجزئة الأثاث، اضغط على قطعة لإضافتها إلى غرفتك. يمكنك بعد ذلك سحبها للتموضع، وقرصها لتغيير الحجم، وتدويرها لضبط الاتجاه.";
"faq.sampleRoom" = "هل يمكنني استخدام غرفة نموذجية بدلاً من غرفتي؟";
"faq.sampleRoomAnswer" = "نعم! يوفر التطبيق غرف نموذجية للتجربة. يمكنك الوصول إليها من قسم الاستكشاف لتجربة وضع الأثاث دون إنشاء غرفتك الخاصة أولاً.";
"faq.accuracy" = "ما مدى دقة النموذج ثلاثي الأبعاد؟";
"faq.accuracyAnswer" = "يوفر النموذج ثلاثي الأبعاد تقريباً جيداً لتخطيط غرفتك. للحصول على أفضل دقة، تأكد من أن صورتك الأصلية تلتقط أبعاد الغرفة بوضوح مع زوايا وحواف مرئية.";
"faq.adjustDimensions" = "هل يمكنني ضبط أبعاد الغرفة؟";
"faq.adjustDimensionsAnswer" = "نعم، انتقل إلى الإعدادات وابحث عن خيارات أبعاد الغرفة حيث يمكنك ضبط حجم ونسب الغرفة المنشأة بدقة.";


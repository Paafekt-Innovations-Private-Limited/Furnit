// FAQ - Room Creation
"faq.roomCreation" = "房間建立";
"faq.howToCreate" = "如何建立3D房間？";
"faq.howToCreateAnswer" = "點擊主畫面左上角的照片圖示，然後拍攝或選擇房間的照片。您將看到兩個選項來建立您的3D房間。";
"faq.howToTakePhoto" = "如何拍照來建立房間？";
"faq.howToTakePhotoAnswer" = "點擊主畫面上的相機圖示直接拍照。您可以選擇標準(1x)或廣角(0.5x超廣角)鏡頭。保持裝置穩定並點擊拍攝按鈕。照片將用於建立您的3D房間。";
"faq.twoMethods" = "What are the two room creation options?";
"faq.twoMethodsAnswer" = "When you select a photo, you can choose between: 1) AI-Powered 3D Room - automatically creates a realistic 3D room using artificial intelligence, or 2) Manual Setup - lets you draw the room boundaries yourself for more control.";
"faq.whatIsAIRoom" = "What is AI-Powered 3D Room?";
"faq.whatIsAIRoomAnswer" = "This option uses smart technology to automatically turn your photo into a 3D room you can walk through. Just pick a photo and the app does the rest - no drawing or adjusting needed. It works like magic!";
"faq.whatIsManualRoom" = "What is Manual Setup?";
"faq.whatIsManualRoomAnswer" = "With Manual Setup, you draw the outline of your room's walls on the photo. This gives you more control over exactly how the 3D room looks. It's great when you want to fine-tune the room shape yourself.";
"faq.whichMethodBetter" = "Which method should I choose?";
"faq.whichMethodBetterAnswer" = "Try AI-Powered first - it's faster and works great for most rooms. If the result doesn't look quite right, use Manual Setup to draw the walls exactly where you want them. You can always try both and see which one you prefer!";
"faq.bestPhotos" = "什麼樣的照片效果最好？";
"faq.bestPhotosAnswer" = "為獲得最佳效果，請在光線充足的環境下拍攝，並保持相機水平。盡量拍攝整個房間，包括地板、牆壁和天花板邊緣。避免模糊或昏暗的照片。";
"faq.generationFailing" = "為什麼我的房間產生失敗？";
"faq.generationFailingAnswer" = "如果照片太暗、模糊或沒有顯示足夠的房間特徵，房間產生可能會失敗。請嘗試在更好的光線下以更寬的角度拍攝新照片。";
"faq.howManyRooms" = "我可以建立多少個房間？";
"faq.howManyRoomsAnswer" = "你最多可以建立10個房間。刪除舊房間以騰出空間。房間數量顯示在主畫面頂部。";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "傢俱分割";
"faq.whatIsSegmentation" = "什麼是傢俱分割？";
"faq.whatIsSegmentationAnswer" = "傢俱分割使用AI識別和分離照片中的傢俱，讓你看到每件傢俱在3D房間中的效果。";
"faq.howToSegment" = "如何從照片中分割傢俱？";
"faq.howToSegmentAnswer" = "檢視3D房間時，點擊傢俱圖示存取分割功能。選擇包含傢俱的照片，應用程式將自動偵測並擷取傢俱。";
"faq.notDetected" = "為什麼我的傢俱沒有被偵測到？";
"faq.notDetectedAnswer" = "傢俱偵測在清晰、光線充足且傢俱明顯可見的照片中效果最佳。確保傢俱沒有被部分遮擋或與背景融合。";
"faq.multiplePieces" = "我可以分割多件傢俱嗎？";
"faq.multiplePiecesAnswer" = "可以！AI可以在單張照片中偵測多件傢俱。每個偵測到的物品將單獨顯示，供你選擇使用。";

// FAQ - 3D Room & Fitment
"faq.roomFitment" = "3D房間與佈置";
"faq.howToView" = "如何檢視我的3D房間？";
"faq.howToViewAnswer" = "點擊主畫面上的任何房間以開啟3D檢視器。你可以使用觸控手勢旋轉、縮放和平移房間。";
"faq.howToPlace" = "如何在房間中放置傢俱？";
"faq.howToPlaceAnswer" = "分割傢俱後，點擊傢俱將其加入房間。然後你可以拖曳定位、捏合調整大小、旋轉調整方向。";
"faq.sampleRoom" = "我可以使用範例房間嗎？";
"faq.sampleRoomAnswer" = "可以！應用程式提供範例房間供你體驗。從探索部分存取它們，無需先建立自己的房間即可嘗試傢俱佈置。";
"faq.accuracy" = "3D模型有多準確？";
"faq.accuracyAnswer" = "3D模型能很好地近似你的房間佈局。為獲得最佳準確度，請確保原始照片清晰地捕捉房間尺寸，包括可見的角落和邊緣。";
"faq.adjustDimensions" = "我可以調整房間尺寸嗎？";
"faq.adjustDimensionsAnswer" = "可以，進入設定並找到房間尺寸選項，你可以微調產生房間的大小和比例。";


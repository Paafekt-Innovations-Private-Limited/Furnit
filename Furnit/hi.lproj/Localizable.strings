"faq.whatIsBrainIconAnswer" = "ब्रेन आइकन SmartyPants identify mode शुरू करता है। यह लाइव कैमरा से फर्नीचर और वस्तुओं को ढूँढता है, लेबल और बॉक्स दिखाता है, और Segment टैप करने से पहले आपको एक या अधिक लेबल चुनने देता है।";
"faq.howToSegmentAnswer" = "रूम व्यूअर में ब्रेन आइकन टैप करें, कैमरा फर्नीचर की ओर करें, एक या अधिक detected labels चुनें, फिर Segment टैप करें। लाइव पहचान पर लौटने के लिए Stop टैप करें।";
"faq.accuracyAnswer" = "3D कमरा एक फोटो से बना अनुमान है। कमरे की डाइमेंशन मार्गदर्शन के लिए उपयोगी हो सकती हैं, लेकिन वे सर्वे-ग्रेड नहीं हैं। फ़र्नीचर मापन AR या depth सपोर्ट वाले फ़ोन पर सबसे अधिक भरोसेमंद होता है।";
"faq.adjustDimensionsAnswer" = "AI-generated SHARP कमरों में सीधे नहीं। कमरे के व्यूअर में ruler का उपयोग करके वर्तमान अनुमानित चौड़ाई, ऊँचाई और गहराई देखें। बेहतर परिणाम के लिए कोने दिखाई देने वाली साफ कमरे की फोटो लें; manual rooms आपकी सेट की गई boundaries का पालन करते हैं।";
"faq.arAssistedSizingAnswer" = "पहले ब्रेन आइकन टैप करें, detected items चुनें, फिर Segment टैप करें। कमरे के अनुपात में scale चाहिए तो sizing control इस्तेमाल करें। AR/depth support वाले फोन पर ऐप live camera depth से अधिक realistic furniture size देती है; depth न होने पर furniture measurements approximate होते हैं।";
"faq.measurementPillAnswer" = "फ़र्नीचर साइज पिल तभी दिखती है जब sizing mode चालू हो और ऐप के पास उपयोगी live height estimate हो। ruler बटन एक छोटे कार्ड में कमरे की मौजूदा चौड़ाई, ऊँचाई और गहराई दिखाता है। non-AR फ़ोन पर ये रीडिंग, खासकर फ़र्नीचर के लिए, कम भरोसेमंद होती हैं।";
"faq.resetOverlayScaleAnswer" = "अब कोई overflow menu नहीं है। अगर ओवरले गलत दिखे तो ब्रेन आइकन बंद करके फिर चालू करें, या फ़र्नीचर को pinch करके हाथ से ठीक आकार दें।";

"faq.pinchOverlaySize" = "सेगमेंट किए गए फर्नीचर को पिंच करने पर क्या होता है?";
"faq.pinchOverlaySizeAnswer" = "पिंच करने पर फर्नीचर ओवरले बड़ा या छोटा होता है। अगर sizing mode चालू है और Furni pill दिख रही है, तो वही pill कमरे के हिसाब से बदले हुए फर्नीचर आकार के अनुमान पर अपडेट हो जाती है। अगर sizing mode बंद है, तो पिंच केवल स्क्रीन पर ओवरले का दृश्य आकार बदलता है।";


    <string name="credits_anthropic_title">Anthropic</string>
    <string name="credits_anthropic_body">Anthropic கருவிகள் ஆய்வு, code assistance, செயலாக்க விவரங்களை ஆராய்தல் மற்றும் மேம்பாட்டு iteration க்கு ஆதரவாக பயன்படுத்தப்பட்டன.</string>

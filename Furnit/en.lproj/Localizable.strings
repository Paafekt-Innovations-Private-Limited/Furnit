// FAQ - Room Creation
"faq.roomCreation" = "Room Creation";
"faq.howToCreate" = "How do I create a 3D room?";
"faq.howToCreateAnswer" = "Tap the photo icon in the top-left corner of the home screen, then take or select a photo of your room. You'll see two options to choose from for creating your 3D room.";
"faq.howToTakePhoto" = "How do I take a photo to create a room?";
"faq.howToTakePhotoAnswer" = "Tap the camera icon on the home screen to take a photo directly. You can choose between Standard (1x) or Wide Angle (0.5x ultra-wide) lens. Hold your device steady and tap the capture button. The photo will then be used to create your 3D room.";
"faq.twoMethods" = "What are the two room creation options?";
"faq.twoMethodsAnswer" = "When you select a photo, you can choose between: 1) AI-Powered 3D Room - automatically creates a realistic 3D room using artificial intelligence, or 2) Manual Setup - lets you draw the room boundaries yourself for more control.";
"faq.whatIsAIRoom" = "What is AI-Powered 3D Room?";
"faq.whatIsAIRoomAnswer" = "This option uses smart technology to automatically turn your photo into a 3D room you can walk through. Just pick a photo and the app does the rest - no drawing or adjusting needed. It works like magic!";
"faq.whatIsManualRoom" = "What is Manual Setup?";
"faq.whatIsManualRoomAnswer" = "With Manual Setup, you draw the outline of your room's walls on the photo. This gives you more control over exactly how the 3D room looks. It's great when you want to fine-tune the room shape yourself.";
"faq.whichMethodBetter" = "Which method should I choose?";
"faq.whichMethodBetterAnswer" = "Try AI-Powered first - it's faster and works great for most rooms. If the result doesn't look quite right, use Manual Setup to draw the walls exactly where you want them. You can always try both and see which one you prefer!";
"faq.bestPhotos" = "What kind of photos work best?";
"faq.bestPhotosAnswer" = "For best results, take photos in good lighting with the camera held level. Try to capture the entire room including floors, walls, and ceiling edges. Avoid blurry or dark photos.";
"faq.generationFailing" = "Why is my room generation failing?";
"faq.generationFailingAnswer" = "Room generation may fail if the photo is too dark, blurry, or doesn't show enough room features. Try taking a new photo with better lighting and a wider angle.";
"faq.howManyRooms" = "How many rooms can I create?";
"faq.howManyRoomsAnswer" = "You can create up to 1000 rooms. Delete older rooms to make space for new ones. The room count and total storage used are shown at the top of your home screen.";
"faq.howToSaveRoom" = "How do I save a room?";
"faq.howToSaveRoomAnswer" = "After generating a 3D room, tap the save icon (download arrow) in the toolbar to save it with a custom name. Rooms that aren't saved will be deleted when you tap Back.";

// FAQ - AI Features
"faq.aiFeatures" = "AI Features";
"faq.whatIsBrainIcon" = "What does the brain icon do?";
"faq.whatIsBrainIconAnswer" = "The brain icon activates SmartyPants - an AI-powered object detection feature. It uses your camera to identify furniture and objects in real-time, showing labels and bounding boxes around detected items.";
"faq.howToScreenshot" = "How do I take a screenshot?";
"faq.howToScreenshotAnswer" = "When SmartyPants is active (brain icon is green), a share icon appears on the bottom-right. Tap it to save a screenshot of the view with AI detections to your Photos library.";
"faq.whatIsSegmentation" = "What is furniture segmentation?";
"faq.whatIsSegmentationAnswer" = "Furniture segmentation uses AI to identify and separate furniture items in your photos, allowing you to see how each piece would fit in your 3D room.";
"faq.howToSegment" = "How do I segment furniture from a photo?";
"faq.howToSegmentAnswer" = "When viewing your 3D room, tap on the brain icon to activate SmartyPants. Point your camera at furniture to see real-time detection with labels.";
"faq.notDetected" = "Why isn't my furniture being detected?";
"faq.notDetectedAnswer" = "Object detection works best with clear, well-lit environments where furniture is clearly visible. Make sure the object isn't partially hidden or too far from the camera.";

// FAQ - 3D Room Controls
"faq.roomControls" = "3D Room Controls";
"faq.howToView" = "How do I view my 3D room?";
"faq.howToViewAnswer" = "Tap on any room in your home screen to open the 3D viewer. Use touch gestures to rotate and zoom, or use the joystick at the bottom to move around inside the room.";
"faq.howToNavigate" = "How do I navigate inside the room?";
"faq.howToNavigateAnswer" = "Use the joystick at the bottom center of the screen to move around. Drag it in any direction to fly through the room. Use the recenter button (viewfinder icon) to reset the camera position.";
"faq.whatIsMemoryDisplay" = "What does the MB number mean?";
"faq.whatIsMemoryDisplayAnswer" = "The MB (megabytes) shown in rooms indicates the file size. This helps you manage storage. The total storage used by all rooms is shown at the top of the home screen.";
"faq.howToPlace" = "How do I place furniture in my room?";
"faq.howToPlaceAnswer" = "After segmenting furniture, tap on the furniture piece to add it to your room. You can then drag to position it, pinch to resize, and rotate to adjust its orientation.";
"faq.sampleRoom" = "Can I use a sample room instead of my own?";
"faq.sampleRoomAnswer" = "Yes! The app provides sample rooms (Vintage Living Room, Cozy Living Room) for you to experiment with. Access them from the home screen to try out features without creating your own room first.";
"faq.accuracy" = "How accurate is the 3D model?";
"faq.accuracyAnswer" = "The 3D model provides a visual approximation of your room's layout. The dimensions shown are relative units from the AI model, not exact real-world measurements.";
"faq.adjustDimensions" = "Can I adjust room dimensions?";
"faq.adjustDimensionsAnswer" = "For USDZ rooms, go to Settings and look for Room Dimensions options. For AI-generated (PLY) rooms, the dimensions are determined by the AI model.";


"faq.howToViewAnswer" = "3D பார்வையாளரைத் திறக்க முகப்பு திரையில் எந்த அறையையும் தட்டவும். தொடு சைகைகளைப் பயன்படுத்தி அறையை சுழற்றலாம், பெரிதாக்கலாம் மற்றும் நகர்த்தலாம்.";
"faq.howToPlace" = "என் அறையில் தளபாடங்களை எப்படி வைப்பது?";
"faq.howToPlaceAnswer" = "தளபாடங்களைப் பிரித்த பிறகு, உங்கள் அறையில் சேர்க்க ஒரு பொருளைத் தட்டவும். நிலைநிறுத்த இழுக்கலாம், அளவை மாற்ற பிஞ்ச் செய்யலாம், திசையை சரிசெய்ய சுழற்றலாம்.";
"faq.sampleRoom" = "என்னுடையதற்கு பதிலாக மாதிரி அறையைப் பயன்படுத்த முடியுமா?";
"faq.sampleRoomAnswer" = "ஆம்! பயன்பாடு பரிசோதிக்க மாதிரி அறைகளை வழங்குகிறது. முதலில் உங்கள் சொந்த அறையை உருவாக்காமல் தளபாட வைப்பை முயற்சிக்க ஆராய் பிரிவிலிருந்து அவற்றை அணுகவும்.";
"faq.accuracy" = "3D மாதிரி எவ்வளவு துல்லியமானது?";
"faq.accuracyAnswer" = "3D மாதிரி உங்கள் அறை அமைப்பின் நல்ல தோராயத்தை வழங்குகிறது. சிறந்த துல்லியத்திற்கு, உங்கள் அசல் புகைப்படம் தெரியும் மூலைகள் மற்றும் விளிம்புகளுடன் அறை பரிமாணங்களை தெளிவாகப் படம்பிடிக்கிறது என்பதை உறுதிப்படுத்தவும்.";
"faq.adjustDimensions" = "அறை பரிமாணங்களை சரிசெய்ய முடியுமா?";
"faq.adjustDimensionsAnswer" = "ஆம், அமைப்புகளுக்குச் சென்று அறை பரிமாண விருப்பங்களைக் கண்டறியவும், அங்கு உருவாக்கப்பட்ட அறையின் அளவு மற்றும் விகிதாச்சாரங்களை நுணுக்கமாக சரிசெய்யலாம்.";
"faq.furnitureMeasurements" = "தளபாடம் & அளவீடுகள்";
"faq.arAssistedSizing" = "AR உதவியுடன் தளபாட அளவீடு என்றால் என்ன?";
"faq.arAssistedSizingAnswer" = "அமைப்புகளில் இயக்கப்பட்டால், பயன்பாடு கேமரா ஆழம் மற்றும் பொருள் கண்டறிதலை இணைத்து நீங்கள் அருகில் அல்லது தொலைவில் நகரும்போது மேலடுக்கு அளவை யதார்த்தமாக மாற்றும். நல்ல வெளிச்சம் மற்றும் தெளிவான பார்வையில் சிறப்பாக வேலை செய்கிறது.";
"faq.measurementPill" = "சிறிய அளவீட்டுக் குறிப்பு என்ன?";
"faq.measurementPillAnswer" = "SmartyPants செயலில் இருக்கும்போது, மதிப்பிடப்பட்ட தளபாடம் மற்றும் அறை உயரம் காட்டப்படலாம். துல்லியத்திற்கு உண்மையான அளவுகளை உள்ளிட தட்டவும். அறைப் படம் வைட்-ஆங்கிள் (0.5×) என்றால் அதைக் குறிக்கவும்.";
"faq.resetOverlayScale" = "முகமூடி தவறாக பெரிதாக்கப்பட்டது போல் தெரிகிறது — என்ன செய்வது?";
"faq.resetOverlayScaleAnswer" = "3D அறையில் மேலதிக மெனுவை (⋮) திறந்து Reset overlay scale ஐத் தேர்ந்தெடுக்கவும். கண்டறிதல் முகமூடிக்கு பயன்பட்ட தானியங்கு பெரிதாக்கம் அழிக்கப்படும்.";
"faq.roomFitment" = "தளபாடம் பொருந்துகிறதா எப்படி சரிபார்ப்பது?";
"faq.roomFitmentAnswer" = "தளபாடத்தைச் சேர்த்த பிறகு, உங்கள் 3D அறையில் அதை மறுஅளவிட்டு நகர்த்தி, உங்கள் இடம் மற்றும் மற்ற தளபாடங்களுடன் எப்படி பொருந்துகிறது என்பதைப் பார்க்கலாம்.";

// FAQ - Placement intelligence & aesthetic
"faq.placementIntelligence" = "இடமமைவு நுண்ணறிவும் அழகியலும்";
"faq.whatIsPlacementIntelligence" = "இடமமைவு நுண்ணறிவு (Placement Intelligence) என்றால் என்ன?";
"faq.whatIsPlacementIntelligenceAnswer" = "ஆதரவுள்ள 3D அறை பார்வையாளர்களில் SmartyPants இயக்கத்தில் இருக்கும்போது, இடமமைவு நுண்ணறிவு அட்டை கண்டறியப்பட்ட பொருளின் அளவு அறை எல்லைக்குள் பொருந்துகிறதா என்று சுருக்குகிறது, கிடைக்கும்போது தரையில் இடம் மற்றும் மூலை பரிந்துரைகளைக் காட்டுகிறது, ஆழம் மதிப்பீடு என்றால் அதைக் குறிப்பிடுகிறது. தலைப்பைத் தட்டி விரிவாகப் பார்க்கவும் அல்லது இடத்தைச் சேமிக்கச் சுருக்கவும்.";
"faq.furnitureColorAesthetic" = "அழகியல் மதிப்பெண்ணுக்கு நிறத்தைப் பயன்பாடு எப்படி தேர்ந்தெடுக்கிறது?";
"faq.furnitureColorAestheticAnswer" = "பயன்பாடு AI தளபாட வெட்டுப்படம் (அதே பிரிப்பு மேலடுக்கு) உள்ளே காணக்கூடிய பிக்சல்களின் RGB சராசரியைக் கணக்கிட்டு தரை, சுவர்கள், மேற்கூரையில் இருந்து மாதிரியெடுக்கப்பட்ட நிறங்களுடன் ஒப்பிடுகிறது. வெட்டுப்படம் தயாராக இல்லையெனில் பிரிப்பு உண்மையான மாதிரி தரும் வரை அறை வண்ணத் தொகுப்பிலிருந்து மாற்று நிறம் பயன்படுத்தப்படும்.";
"faq.whatDoHarmonyContrastMean" = "இசைவு, வேறுபாடு, பாணி பொருத்தம் என்றால் என்ன?";
"faq.whatDoHarmonyContrastMeanAnswer" = "இவை எளிய வடிவமைப்பு விதிகள், சுவைத் தீர்ப்பு அல்ல. இசைவு தளபாட நிறம் அறை வண்ணத் தொகுப்புடன் எவ்வாறு தொடர்புடையது என்பதை விவரிக்கிறது (உதா. நெருக்கமான அல்லது நிறைவு நிறங்கள்). வேறுபாடு வழக்கமான தரை அல்லது சுவர் ஒளிர்வுடன் வித்தியாசத்தை அளக்கிறது. பாணி பொருத்தம் அறைக்கு அனுமானிக்கப்பட்ட பரந்த பாணி குறிச்சொற்களை இயல்புநிலை நவீன சுயவிவரத்துடன் ஒப்பிடுகிறது—எனவே தோராயமானது.";
"faq.whenDoesAestheticScoreLow" = "எப்போது அழகியல் மதிப்பெண் குறைவாகத் தோன்றலாம் அல்லது \"clash\" காணலாம்?";
"faq.whenDoesAestheticScoreLowAnswer" = "பிரகாசமான, செறிவான பொருள்கள் பெரும்பாலும் குறைந்த மதிப்பெண் பெறும் அவற்றின் நிறத் தொனி உங்கள் அறை மாதிரியுடன் பயன்பாட்டின் இசைவு விதிகளுடன் பொருந்தாதபோது—உதா. ஆசிட் பச்சை, மெஜென்டா, ஊதா அல்லது பாதுகாப்பு ஆரஞ்சு வெப்ப பேஜ் அல்லது பழுப்பு அறைகளில், அல்லது ஏறக்குறைய ஒரே நிற அறையில் கூச்சலிடும் முதன்மை நிறங்கள். தரை அல்லது சுவருடன் ஒளிர்வு மிக நெருக்கமாக (பழுப்பில் பழுப்பு, சாம்பலில் சாம்பல்) வேறுபாட்டைக் குறைக்கலாம் உங்களுக்குப் பிடித்திருந்தாலும். நாட்டுப்புற அல்லது பாரம்பரிய அறைகளில் பாணி பொருத்தம் குறைவாக இருக்கலாம் ஏனெனில் தளபாட சுயவிவரம் இயல்புநிலை நவீன/குறைந்தபட்ச குறிச்சொற்களைப் பயன்படுத்துகிறது. இரைச்சலான பின்னணியிலிருந்து மங்கிய சாம்பல் சராசரி சிலநேரம் \"நடுநிலை\" வட்டத்தில் விழும் clash அல்ல. மதிப்பெண்கள் வழிகாட்டிகள் மட்டுமே; உண்மை அலங்காரத்தில் உங்கள் கண்ணை நம்புங்கள்.";


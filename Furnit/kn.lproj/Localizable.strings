"faq.howToCreateAnswer" = "ಹೋಮ್ ಸ್ಕ್ರೀನ್‌ನ ಮೇಲಿನ-ಎಡ ಮೂಲೆಯಲ್ಲಿ ಫೋಟೋ ಐಕಾನ್ ಟ್ಯಾಪ್ ಮಾಡಿ, ನಂತರ ನಿಮ್ಮ ಕೊಠಡಿಯ ಫೋಟೋ ತೆಗೆದುಕೊಳ್ಳಿ ಅಥವಾ ಆಯ್ಕೆಮಾಡಿ. ನಿಮ್ಮ 3D ಕೊಠಡಿ ರಚಿಸಲು ಎರಡು ಆಯ್ಕೆಗಳನ್ನು ನೀವು ನೋಡುತ್ತೀರಿ.";
"faq.howToTakePhoto" = "ಕೊಠಡಿ ರಚಿಸಲು ಫೋಟೋ ಹೇಗೆ ತೆಗೆದುಕೊಳ್ಳುವುದು?";
"faq.howToTakePhotoAnswer" = "ನೇರವಾಗಿ ಫೋಟೋ ತೆಗೆದುಕೊಳ್ಳಲು ಹೋಮ್ ಸ್ಕ್ರೀನ್‌ನಲ್ಲಿ ಕ್ಯಾಮೆರಾ ಐಕಾನ್ ಟ್ಯಾಪ್ ಮಾಡಿ. ನೀವು ಸ್ಟ್ಯಾಂಡರ್ಡ್ (1x) ಅಥವಾ ವೈಡ್ ಆಂಗಲ್ (0.5x ಅಲ್ಟ್ರಾ-ವೈಡ್) ಲೆನ್ಸ್ ಆಯ್ಕೆಮಾಡಬಹುದು. ನಿಮ್ಮ ಸಾಧನವನ್ನು ಸ್ಥಿರವಾಗಿ ಹಿಡಿದು ಕ್ಯಾಪ್ಚರ್ ಬಟನ್ ಟ್ಯಾಪ್ ಮಾಡಿ. ಫೋಟೋವನ್ನು ನಿಮ್ಮ 3D ಕೊಠಡಿ ರಚಿಸಲು ಬಳಸಲಾಗುತ್ತದೆ.";
"faq.depthAwareRoomPhoto" = "ಅಪ್ಲಿಕೇಶನ್‌ನಲ್ಲಿ ಫೋಟೋ ತೆಗೆದುಕೊಳ್ಳುವುದು ಕೊಠಡಿಯ ಗುಣಮಟ್ಟವನ್ನು ಉತ್ತಮಗೊಳಿಸುತ್ತದೆಯೇ?";
"faq.depthAwareRoomPhotoAnswer" = "ಹೌದು. ಬೆಂಬಲಿತ ಸಾಧನಗಳಲ್ಲಿ, ಗ್ಯಾಲರಿಯಿಂದ ಆಯ್ಕೆಮಾಡುವ ಬದಲು «ಫೋಟೋ ತೆಗೆದುಕೊಳ್ಳಿ» ಆಯ್ಕೆಮಾಡುವುದು ಲಭ್ಯವಿರುವಲ್ಲಿ ಆಳ-ಮಾಹಿತಿಯೊಂದಿಗೆ ಇನ್-ಅಪ್ ಕ್ಯಾಮರಾವನ್ನು ಬಳಸುತ್ತದೆ; ಇದು ನಿಮ್ಮ 3D ಕೊಠಡಿಯ ನಿರ್ಮಾಣ ಮತ್ತು ಪ್ರಮಾಣಕ್ಕೆ ಸುಧಾರಣೆ ತರುಬಹುದು.";
"faq.twoMethods" = "ಎರಡು ಕೊಠಡಿ ರಚನಾ ಆಯ್ಕೆಗಳು ಯಾವುವು?";
"faq.twoMethodsAnswer" = "ಫೋಟೋ ಆಯ್ಕೆಮಾಡಿದಾಗ ನೀವು ಆಯ್ಕೆಮಾಡಬಹುದು: 1) AI-ಚಾಲಿತ 3D ಕೊಠಡಿ - ಕೃತಕ ಬುದ್ಧಿಮತ್ತೆಯನ್ನು ಬಳಸಿ ಸ್ವಯಂಚಾಲಿತವಾಗಿ ವಾಸ್ತವಿಕ 3D ಕೊಠಡಿಯನ್ನು ರಚಿಸುತ್ತದೆ, ಅಥವಾ 2) ಮ್ಯಾನುಯಲ್ ಸೆಟಪ್ - ಹೆಚ್ಚಿನ ನಿಯಂತ್ರಣಕ್ಕಾಗಿ ಕೊಠಡಿ ಗಡಿಗಳನ್ನು ನೀವೇ ಬರೆಯಲು ಅನುಮತಿಸುತ್ತದೆ.";
"faq.whatIsAIRoom" = "AI-ಚಾಲಿತ 3D ಕೊಠಡಿ ಎಂದರೇನು?";
"faq.whatIsAIRoomAnswer" = "ಈ ಆಯ್ಕೆಯು ನಿಮ್ಮ ಫೋಟೋವನ್ನು ನೀವು ನಡೆಯಬಹುದಾದ 3D ಕೊಠಡಿಗೆ ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಪರಿವರ್ತಿಸಲು ಸ್ಮಾರ್ಟ್ ತಂತ್ರಜ್ಞಾನವನ್ನು ಬಳಸುತ್ತದೆ. ಫೋಟೋ ಆಯ್ಕೆಮಾಡಿ ಅಪ್ಲಿಕೇಶನ್ ಉಳಿದದ್ದನ್ನು ಮಾಡುತ್ತದೆ - ಚಿತ್ರಿಸುವ ಅಥವಾ ಹೊಂದಾಣಿಕೆ ಅಗತ್ಯವಿಲ್ಲ. ಮ್ಯಾಜಿಕ್‌ನಂತೆ ಕೆಲಸ ಮಾಡುತ್ತದೆ!";
"faq.whatIsManualRoom" = "ಮ್ಯಾನುಯಲ್ ಸೆಟಪ್ ಎಂದರೇನು?";
"faq.whatIsManualRoomAnswer" = "ಮ್ಯಾನುಯಲ್ ಸೆಟಪ್‌ನೊಂದಿಗೆ, ಫೋಟೋದಲ್ಲಿ ನಿಮ್ಮ ಕೊಠಡಿಯ ಗೋಡೆಗಳ ರೂಪರೇಖೆಯನ್ನು ನೀವು ಬರೆಯಿರಿ. 3D ಕೊಠಡಿ ನಿಖರವಾಗಿ ಹೇಗೆ ಕಾಣುತ್ತದೆ ಎಂಬುದರ ಮೇಲೆ ಹೆಚ್ಚಿನ ನಿಯಂತ್ರಣ ನೀಡುತ್ತದೆ. ಕೊಠಡಿ ಆಕಾರವನ್ನು ನೀವೇ ಸೂಕ್ಷ್ಮವಾಗಿ ಹೊಂದಿಸಲು ಬಯಸಿದಾಗ ಉತ್ತಮ.";
"faq.whichMethodBetter" = "ನಾನು ಯಾವ ವಿಧಾನವನ್ನು ಆಯ್ಕೆಮಾಡಬೇಕು?";
"faq.whichMethodBetterAnswer" = "ಮೊದಲು AI-ಚಾಲಿತ ಪ್ರಯತ್ನಿಸಿ - ಅದು ವೇಗವಾಗಿದೆ ಮತ್ತು ಬಹುತೇಕ ಕೊಠಡಿಗಳಿಗೆ ಉತ್ತಮವಾಗಿ ಕೆಲಸ ಮಾಡುತ್ತದೆ. ಫಲಿತಾಂಶ ಸರಿಯಾಗಿ ಕಾಣದಿದ್ದರೆ, ಗೋಡೆಗಳನ್ನು ನಿಮಗೆ ಬೇಕಾದ ನಿಖರ ಸ್ಥಳದಲ್ಲಿ ಬರೆಯಲು ಮ್ಯಾನುಯಲ್ ಸೆಟಪ್ ಬಳಸಿ. ನೀವು ಎರಡನ್ನೂ ಪ್ರಯತ್ನಿಸಿ ಯಾವುದನ್ನು ಆದ್ಯತೆ ನೀಡುತ್ತೀರಿ ನೋಡಬಹುದು!";
"faq.bestPhotos" = "ಯಾವ ರೀತಿಯ ಫೋಟೋಗಳು ಉತ್ತಮವಾಗಿ ಕಾರ್ಯನಿರ್ವಹಿಸುತ್ತವೆ?";
"faq.bestPhotosAnswer" = "ಉತ್ತಮ ಫಲಿತಾಂಶಗಳಿಗಾಗಿ, ಉತ್ತಮ ಬೆಳಕಿನಲ್ಲಿ ಸಾಧನವನ್ನು ಸ್ಥಿರವಾಗಿ ಹಿಡಿದು ಫೋಟೋಗಳನ್ನು ತೆಗೆದುಕೊಳ್ಳಿ. ನೆಲ, ಗೋಡೆಗಳು ಮತ್ತು ಸೀಲಿಂಗ್ ಅಂಚುಗಳನ್ನು ಒಳಗೊಂಡಂತೆ ಸಂಪೂರ್ಣ ಕೊಠಡಿಯನ್ನು ಸೆರೆಹಿಡಿಯಲು ಪ್ರಯತ್ನಿಸಿ. ಮಸುಕಾದ ಅಥವಾ ಕತ್ತಲೆಯ ಫೋಟೋಗಳನ್ನು ತಪ್ಪಿಸಿ.";
"faq.generationFailing" = "ನನ್ನ ಕೊಠಡಿ ರಚನೆ ಏಕೆ ವಿಫಲವಾಗುತ್ತಿದೆ?";
"faq.generationFailingAnswer" = "ಫೋಟೋ ತುಂಬಾ ಕತ್ತಲೆಯಾಗಿದ್ದರೆ, ಮಸುಕಾಗಿದ್ದರೆ, ಅಥವಾ ಸಾಕಷ್ಟು ಕೊಠಡಿ ವೈಶಿಷ್ಟ್ಯಗಳನ್ನು ತೋರಿಸದಿದ್ದರೆ ಕೊಠಡಿ ರಚನೆ ವಿಫಲವಾಗಬಹುದು. ಉತ್ತಮ ಬೆಳಕು ಮತ್ತು ಅಗಲ ಕೋನದೊಂದಿಗೆ ಹೊಸ ಫೋಟೋ ತೆಗೆದುಕೊಳ್ಳಲು ಪ್ರಯತ್ನಿಸಿ.";
"faq.howManyRooms" = "ನಾನು ಎಷ್ಟು ಕೊಠಡಿಗಳನ್ನು ರಚಿಸಬಹುದು?";
"faq.howManyRoomsAnswer" = "ನೀವು 1000 ಕೊಠಡಿಗಳವರೆಗೆ ರಚಿಸಬಹುದು. ಸ್ಥಳ ಮಾಡಲು ಹಳೆಯ ಕೊಠಡಿಗಳನ್ನು ಅಳಿಸಿ. ಕೊಠಡಿ ಸಂಖ್ಯೆಯು ನಿಮ್ಮ ಹೋಮ್ ಸ್ಕ್ರೀನ್‌ನ ಮೇಲ್ಭಾಗದಲ್ಲಿ ಪ್ರದರ್ಶಿಸಲಾಗುತ್ತದೆ.";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "ಪೀಠೋಪಕರಣ ವಿಭಜನೆ";
"faq.whatIsSegmentation" = "ಪೀಠೋಪಕರಣ ವಿಭಜನೆ ಎಂದರೇನು?";
"faq.whatIsSegmentationAnswer" = "ಪೀಠೋಪಕರಣ ವಿಭಜನೆ AI ಬಳಸಿ ನಿಮ್ಮ ಫೋಟೋಗಳಲ್ಲಿ ಪೀಠೋಪಕರಣಗಳನ್ನು ಗುರುತಿಸುತ್ತದೆ ಮತ್ತು ಬೇರ್ಪಡಿಸುತ್ತದೆ, ಪ್ರತಿ ತುಂಡು ನಿಮ್ಮ 3D ಕೊಠಡಿಯಲ್ಲಿ ಹೇಗೆ ಹೊಂದುತ್ತದೆ ಎಂಬುದನ್ನು ನೋಡಲು ಅನುಮತಿಸುತ್ತದೆ.";
"faq.howToSegment" = "ಫೋಟೋದಿಂದ ಪೀಠೋಪಕರಣಗಳನ್ನು ಹೇಗೆ ವಿಭಜಿಸುವುದು?";
"faq.howToSegmentAnswer" = "ನಿಮ್ಮ 3D ಕೊಠಡಿಯನ್ನು ವೀಕ್ಷಿಸುವಾಗ, ವಿಭಜನೆ ವೈಶಿಷ್ಟ್ಯವನ್ನು ಪ್ರವೇಶಿಸಲು ಪೀಠೋಪಕರಣ ಐಕಾನ್ ಟ್ಯಾಪ್ ಮಾಡಿ. ಪೀಠೋಪಕರಣ ಹೊಂದಿರುವ ಫೋಟೋ ಆಯ್ಕೆಮಾಡಿ, ಮತ್ತು ಅಪ್ಲಿಕೇಶನ್ ಪೀಠೋಪಕರಣ ವಸ್ತುಗಳನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಪತ್ತೆಹಚ್ಚಿ ಹೊರತೆಗೆಯುತ್ತದೆ.";
"faq.notDetected" = "ನನ್ನ ಪೀಠೋಪಕರಣ ಏಕೆ ಪತ್ತೆಯಾಗುತ್ತಿಲ್ಲ?";
"faq.notDetectedAnswer" = "ಪೀಠೋಪಕರಣ ಪತ್ತೆಯು ಸ್ಪಷ್ಟ, ಉತ್ತಮ ಬೆಳಕಿನ ಫೋಟೋಗಳಲ್ಲಿ ಪೀಠೋಪಕರಣ ಸ್ಪಷ್ಟವಾಗಿ ಗೋಚರಿಸಿದಾಗ ಉತ್ತಮವಾಗಿ ಕಾರ್ಯನಿರ್ವಹಿಸುತ್ತದೆ. ಪೀಠೋಪಕರಣ ಭಾಗಶಃ ಮುಚ್ಚಲಾಗಿಲ್ಲ ಅಥವಾ ಹಿನ್ನೆಲೆಯೊಂದಿಗೆ ಮಿಶ್ರಣವಾಗಿಲ್ಲ ಎಂದು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ.";
"faq.multiplePieces" = "ಅನೇಕ ಪೀಠೋಪಕರಣ ತುಂಡುಗಳನ್ನು ವಿಭಜಿಸಬಹುದೇ?";
"faq.multiplePiecesAnswer" = "ಹೌದು! AI ಒಂದೇ ಫೋಟೋದಲ್ಲಿ ಅನೇಕ ಪೀಠೋಪಕರಣ ತುಂಡುಗಳನ್ನು ಪತ್ತೆಹಚ್ಚಬಹುದು. ಪ್ರತಿ ಪತ್ತೆಯಾದ ವಸ್ತುವನ್ನು ಪ್ರತ್ಯೇಕವಾಗಿ ಪ್ರದರ್ಶಿಸಲಾಗುತ್ತದೆ ನೀವು ಯಾವುದನ್ನು ಬಳಸಬೇಕೆಂದು ಆಯ್ಕೆ ಮಾಡಲು.";

// FAQ - 3D Room & Fitment
"faq.howToView" = "ನನ್ನ 3D ಕೊಠಡಿಯನ್ನು ಹೇಗೆ ವೀಕ್ಷಿಸುವುದು?";
"faq.howToViewAnswer" = "3D ವೀಕ್ಷಕವನ್ನು ತೆರೆಯಲು ಹೋಮ್ ಸ್ಕ್ರೀನ್‌ನಲ್ಲಿ ಯಾವುದೇ ಕೊಠಡಿಯನ್ನು ಟ್ಯಾಪ್ ಮಾಡಿ. ಟಚ್ ಜೆಸ್ಚರ್‌ಗಳನ್ನು ಬಳಸಿ ಕೊಠಡಿಯನ್ನು ತಿರುಗಿಸಬಹುದು, ಜೂಮ್ ಮಾಡಬಹುದು ಮತ್ತು ಪ್ಯಾನ್ ಮಾಡಬಹುದು.";
"faq.howToPlace" = "ನನ್ನ ಕೊಠಡಿಯಲ್ಲಿ ಪೀಠೋಪಕರಣ ಹೇಗೆ ಇಡುವುದು?";
"faq.howToPlaceAnswer" = "ಪೀಠೋಪಕರಣ ವಿಭಜಿಸಿದ ನಂತರ, ನಿಮ್ಮ ಕೊಠಡಿಗೆ ಸೇರಿಸಲು ತುಂಡನ್ನು ಟ್ಯಾಪ್ ಮಾಡಿ. ನಂತರ ಸ್ಥಾನಕ್ಕೆ ಎಳೆಯಬಹುದು, ಗಾತ್ರ ಬದಲಾಯಿಸಲು ಪಿಂಚ್ ಮಾಡಬಹುದು, ಮತ್ತು ದಿಕ್ಕು ಹೊಂದಿಸಲು ತಿರುಗಿಸಬಹುದು.";
"faq.sampleRoom" = "ನನ್ನದರ ಬದಲು ಮಾದರಿ ಕೊಠಡಿ ಬಳಸಬಹುದೇ?";
"faq.sampleRoomAnswer" = "ಹೌದು! ಅಪ್ಲಿಕೇಶನ್ ಪ್ರಯೋಗಿಸಲು ಮಾದರಿ ಕೊಠಡಿಗಳನ್ನು ಒದಗಿಸುತ್ತದೆ. ಮೊದಲು ನಿಮ್ಮ ಸ್ವಂತ ಕೊಠಡಿ ರಚಿಸದೆ ಪೀಠೋಪಕರಣ ಇರಿಸುವಿಕೆ ಪ್ರಯತ್ನಿಸಲು ಎಕ್ಸ್‌ಪ್ಲೋರ್ ವಿಭಾಗದಿಂದ ಅವುಗಳನ್ನು ಪ್ರವೇಶಿಸಿ.";
"faq.accuracy" = "3D ಮಾದರಿ ಎಷ್ಟು ನಿಖರ?";
"faq.accuracyAnswer" = "3D ಮಾದರಿ ನಿಮ್ಮ ಕೊಠಡಿ ವಿನ್ಯಾಸದ ಉತ್ತಮ ಅಂದಾಜನ್ನು ಒದಗಿಸುತ್ತದೆ. ಉತ್ತಮ ನಿಖರತೆಗಾಗಿ, ನಿಮ್ಮ ಮೂಲ ಫೋಟೋ ಗೋಚರ ಮೂಲೆಗಳು ಮತ್ತು ಅಂಚುಗಳೊಂದಿಗೆ ಕೊಠಡಿ ಆಯಾಮಗಳನ್ನು ಸ್ಪಷ್ಟವಾಗಿ ಸೆರೆಹಿಡಿಯುತ್ತದೆ ಎಂದು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ.";
"faq.adjustDimensions" = "ಕೊಠಡಿ ಆಯಾಮಗಳನ್ನು ಹೊಂದಿಸಬಹುದೇ?";
"faq.adjustDimensionsAnswer" = "ಹೌದು, ಸೆಟ್ಟಿಂಗ್‌ಗಳಿಗೆ ಹೋಗಿ ಮತ್ತು ಕೊಠಡಿ ಆಯಾಮ ಆಯ್ಕೆಗಳನ್ನು ಹುಡುಕಿ ಅಲ್ಲಿ ನೀವು ರಚಿಸಿದ ಕೊಠಡಿಯ ಗಾತ್ರ ಮತ್ತು ಅನುಪಾತಗಳನ್ನು ಸರಿಯಾಗಿ ಹೊಂದಿಸಬಹುದು.";
"faq.furnitureMeasurements" = "ಪೀಠೋಪಕರಣ ಮತ್ತು ಅಳತೆಗಳು";
"faq.arAssistedSizing" = "ಫರ್ನಿಚರ್ ಓವರ್ಲೇ ಗಾತ್ರವನ್ನು ಹೇಗೆ ಅಂದಾಜು ಮಾಡಲಾಗುತ್ತದೆ?";
"faq.arAssistedSizingAnswer" = "ARKit ವಿಶ್ವ ಟ್ರ್ಯಾಕಿಂಗ್ ಬೆಂಬಲವಿರುವ ಸಾಧನಗಳಲ್ಲಿ, ಅಪ್ಲಿಕೇಶನ್ ಕ್ಯಾಮೆರಾ ಆಳ ಮತ್ತು ಇಂಟ್ರಿನ್ಸಿಕ್ಸ್ ಬಳಸಿ ನೀವು ಚಲಿಸಿದಂತೆ ಓವರ್ಲೇಯನ್ನು ನೈಜ ಮೀಟರ್‌ಗಳಲ್ಲಿ ಸ್ಕೇಲ್ ಮಾಡುತ್ತದೆ. AR ಬೆಂಬಲವಿಲ್ಲದಿದ್ದರೆ, ನಿಮ್ಮ 3D ಕೊಠಡಿ ಅಳತೆಗಳನ್ನು ಬಳಸಲಾಗುತ್ತದೆ; ನೀವು ಇನ್ನೂ ಪಿಂಚ್ ಮಾಡಿ ಓವರ್ಲೇ ಹೊಂದಿಸಬಹುದು.";
"faq.measurementPill" = "ಚಿಕ್ಕ ಅಳತೆ ಓದುವಿಕೆ (ಪಿಲ್) ಏನು?";
"faq.measurementPillAnswer" = "SmartyPants ಸಕ್ರಿಯವಾಗಿದ್ದಾಗ, ಪೀಠೋಪಕರಣದ ಮತ್ತು ಕೊಠಡಿಯ ಅಂದಾಜು ಎತ್ತರಗಳನ್ನು ತೋರಿಸುವ ಪಿಲ್ ಕಾಣಬಹುದು. ಉತ್ತಮ ನಿಖರತೆಗಾಗಿ ನಿಜವಾದ ಅಳತೆಗಳನ್ನು ನಮೂದಿಸಲು ಅದನ್ನು ಟ್ಯಾಪ್ ಮಾಡಿ. ನಿಮ್ಮ ಕೊಠಡಿ ಫೋಟೋ ವೈಡ್-ಆಂಗಲ್ (0.5×) ಲೆನ್ಸ್‌ನಲ್ಲಿ ತೆಗೆದಿದ್ದರೆ, ಆಯ್ಕೆಯನ್ನು ಗುರುತಿಸಿ — ಚೌಕಟ್ಟು ಸ್ಥಿರವಾಗಿ ಉಳಿಯುತ್ತದೆ.";
"faq.resetOverlayScale" = "ಪೀಠೋಪಕರಣ ಮಾಸ್ಕ್ ತಪ್ಪಾಗಿ ಜೂಮ್ ಆಗಿದೆ ಎನಿಸುತ್ತದೆ — ಏನು ಮಾಡಲಿ?";
"faq.resetOverlayScaleAnswer" = "3D ಕೊಠಡಿಯಲ್ಲಿ ಓವರ್‌ಫ್ಲೋ ಮೆನು (⋮) ತೆರೆದು «ಓವರ್ಲೇ ಪ್ರಮಾಣ ಮರುಹೊಂದಿಸಿ» ಆಯ್ಕೆಮಾಡಿ. ಪತ್ತೆ ಓವರ್ಲೇಗೆ ಅನ್ವಯಿಸಿದ ಸ್ವಯಂಚಾಲಿತ ಜೂಮ್ ಅನ್ನು ಅದು ತೆರವುಗೊಳಿಸುತ್ತದೆ; ನೀವು ಚಲಿಸಿದಂತೆ ಮತ್ತೆ ಸರಿಯಾಗಿ ಹೊಂದಿಕೊಳ್ಳುತ್ತದೆ.";
"faq.roomFitment" = "ಪೀಠೋಪಕರಣ ಸರಿಯಾಗಿ ಹೊಂದುತ್ತದೆಯೇ ಎಂದು ಹೇಗೆ ಪರಿಶೀಲಿಸುವುದು?";
"faq.roomFitmentAnswer" = "ಪೀಠೋಪಕರಣ ಸೇರಿಸಿದ ನಂತರ, ನಿಮ್ಮ 3D ಕೊಠಡಿಯಲ್ಲಿ ಅದರ ಗಾತ್ರ ಬದಲಾಯಿಸಿ ಮತ್ತು ಸ್ಥಾನ ಸರಿಸಿ — ನಿಮ್ಮ ಖಾಲಿ ಜಾಗ ಮತ್ತು ಇತರ ಪೀಠೋಪಕರಣಗಳೊಂದಿಗೆ ಹೇಗೆ ಹೊಂದುತ್ತದೆ ಎಂದು ನೋಡಬಹುದು.";

// FAQ - Placement intelligence & aesthetic
"faq.placementIntelligence" = "ಪ್ಲೇಸ್‌ಮೆಂಟ್ ಬುದ್ಧಿಮತ್ತೆ ಮತ್ತು ಸೌಂದರ್ಯ";
"faq.whatIsPlacementIntelligence" = "ಪ್ಲೇಸ್‌ಮೆಂಟ್ ಇಂಟೆಲಿಜೆನ್ಸ್ ಎಂದರೇನು?";
"faq.whatIsPlacementIntelligenceAnswer" = "ಬೆಂಬಲಿತ 3D ರೂಮ್ ವ್ಯೂವರ್‌ಗಳಲ್ಲಿ SmartyPants ಆನ್ ಆಗಿದ್ದಾಗ, ಪ್ಲೇಸ್‌ಮೆಂಟ್ ಇಂಟೆಲಿಜೆನ್ಸ್ ಕಾರ್ಡ್ ಪತ್ತೆಯಾದ ವಸ್ತುವಿನ ಗಾತ್ರ ಕೊಠಡಿಯ ಮಿತಿಗಳೊಳಗೆ ಸರಿಹೊಂದುತ್ತದೆಯೇ ಎಂದು ಸಾರಾಂಶಿಸುತ್ತದೆ, ಲಭ್ಯವಿದ್ದಾಗ ನೆಲದ ಖಾಲಿ ಜಾಗದ ಸೂಚನೆಗಳು ಮತ್ತು ಮೂಲೆ ಸಲಹೆಗಳನ್ನು ತೋರಿಸುತ್ತದೆ, ಮತ್ತು ಆಳ ಅಂದಾಜು ಎಂದಾಗ ಅದನ್ನು ಹೇಳುತ್ತದೆ. ಶೀರ್ಷಿಕೆಯನ್ನು ಟ್ಯಾಪ್ ಮಾಡಿ ವಿವರಗಳನ್ನು ವಿಸ್ತೃತವಾಗಿ ನೋಡಿ ಅಥವಾ ಸ್ಥಳ ಉಳಿಸಲು ಕುಗ್ಗಿಸಿ.";
"faq.furnitureColorAesthetic" = "ಸೌಂದರ್ಯ ಅಂಕಕ್ಕೆ ಬಣ್ಣವನ್ನು ಅಪ್ಲಿಕೇಶನ್ ಹೇಗೆ ಆಯ್ಕೆ ಮಾಡುತ್ತದೆ?";
"faq.furnitureColorAestheticAnswer" = "ಅಪ್ಲಿಕೇಶನ್ ನೀವು ನೋಡುವ AI ಪೀಠೋಪಕರಣ ಕಟ್‌ಔಟ್ (ಅದೇ ವಿಭಜಿತ ಓವರ್‌ಲೇ) ಒಳಗಿನ ಗೋಚರ ಪಿಕ್ಸೆಲ್‌ಗಳ RGB ಸರಾಸರಿ ಲೆಕ್ಕಿಸುತ್ತದೆ ಮತ್ತು ಅದನ್ನು ನೆಲ, ಗೋಡೆಗಳು ಮತ್ತು ಛತದಿಂದ ಮಾದರಿ ಮಾಡಿದ ಬಣ್ಣಗಳೊಂದಿಗೆ ಹೋಲಿಸುತ್ತದೆ. ಕಟ್‌ಔಟ್ ಸಿದ್ಧವಾಗದಿದ್ದರೆ ವಿಭಜನೆ ನಿಜವಾದ ಮಾದರಿ ನೀಡುವವರೆಗೆ ಕೊಠಡಿ ಪ್ಯಾಲೆಟ್‌ನಿಂದ ಬದಲಿ ಬಣ್ಣ ಬಳಸಲಾಗುತ್ತದೆ.";
"faq.whatDoHarmonyContrastMean" = "ಸಾಮರಸ್ಯ, ಕಾಂಟ್ರಾಸ್ಟ್ ಮತ್ತು ಶೈಲಿ ಹೊಂದಾಣಿಕೆ ಎಂದರೇನು?";
"faq.whatDoHarmonyContrastMeanAnswer" = "ಇವು ಸರಳ ವಿನ್ಯಾಸ ಮಾರ್ಗದರ್ಶನಗಳು, ರುಚಿಯ ತೀರ್ಮಾನವಲ್ಲ. ಸಾಮರಸ್ಯವು ಪೀಠೋಪಕರಣದ ಬಣ್ಣ ಕೊಠಡಿಯ ಪ್ಯಾಲೆಟ್‌ಗೆ ಹೇಗೆ ಸಂಬಂಧಿಸುತ್ತದೆ ಎಂದು ವಿವರಿಸುತ್ತದೆ (ಉದಾ. ಹತ್ತಿರದ ಅಥವಾ ಪೂರಕ ವರ್ಣಗಳು). ಕಾಂಟ್ರಾಸ್ಟ್ ಸಾಮಾನ್ಯ ನೆಲ ಅಥವಾ ಗೋಡೆಯ ಪ್ರಕಾಶಕ್ಕೆ ವ್ಯತ್ಯಾಸವನ್ನು ಅಳಕೆ ಹಾಕುತ್ತದೆ. ಶೈಲಿ ಹೊಂದಾಣಿಕೆ ಕೊಠಡಿಗೆ ಅನುಮಾನಿಸಲಾದ ವಿಶಾಲ ಶೈಲಿ ಟ್ಯಾಗ್‌ಗಳನ್ನು ಡೀಫಾಲ್ಟ್ ಆಧುನಿಕ ಪ್ರೊಫೈಲ್‌ನೊಂದಿಗೆ ಹೋಲಿಸುತ್ತದೆ—ಆದ್ದರಿಂದ ಅಂದಾಜು.";
"faq.whenDoesAestheticScoreLow" = "ಯಾವಾಗ ಸೌಂದರ್ಯ ಅಂಕ ಕಡಿಮೆ ಕಾಣಬಹುದು ಅಥವಾ \"clash\" ಕಾಣಿಸಬಹುದು?";
"faq.whenDoesAestheticScoreLowAnswer" = "ಹೊಳೆಯುವ, ಸಂಪೃಕ್ತ ವಸ್ತುಗಳು ಅನೇಕ ಬಾರಿ ಕಡಿಮೆ ಅಂಕ ಪಡೆಯುತ್ತವೆ ಯಾವಾಗ ಅವುಗಳ ವರ್ಣ ಟೋನ್ ನಿಮ್ಮ ಕೊಠಡಿಯ ಮಾದರಿಗೆ ಅಪ್ಲಿಕೇಶನ್‌ನ ಸಾಮರಸ್ಯ ನಿಯಮಗಳೊಂದಿಗೆ ಹೊಂದಿಕೆಯಾಗದಿದ್ದಾಗ—ಉದಾ. ಆಸಿಡ್ ಗ್ರೀನ್, ಮ್ಯಾಜೆಂಟಾ, ನೇರಳೆ ಅಥವಾ ಸೇಫ್ಟಿ-ಆರೆಂಜ್ ಬೆಚ್ಚಗಿನ ಬೇಜ್ ಅಥವಾ ಕಂದು ಕೊಠಡಿಗಳಲ್ಲಿ, ಅಥವಾ ಬಹುತೇಕ ಏಕವರ್ಣದ ಕೊಠಡಿಯಲ್ಲಿ ಜೋರಾದ ಪ್ರೈಮರಿ ಬಣ್ಣಗಳು. ನೆಲ ಅಥವಾ ಗೋಡೆಯ ಪ್ರಕಾಶಕ್ಕೆ ಬಹಳ ಹತ್ತಿರ (ಕಂದು ಮೇಲೆ ಕಂದು, ಬೂದು ಮೇಲೆ ಬೂದು) ಕಾಂಟ್ರಾಸ್ಟ್ ಕಡಿಮೆ ಮಾಡಬಹುದು ನಿಮಗೆ ಇಷ್ಟವಿದ್ದರೂ. ರಸ್ಟಿಕ್ ಅಥವಾ ಸಾಂಪ್ರದಾಯಿಕ ಕೊಠಡಿಗಳಲ್ಲಿ ಶೈಲಿ ಹೊಂದಾಣಿಕೆ ಕಡಿಮೆ ಇರಬಹುದು ಏಕೆಂದರೆ ಪೀಠೋಪಕರಣ ಪ್ರೊಫೈಲ್ ಡೀಫಾಲ್ಟ್ ಆಧುನಿಕ/ಮಿನಿಮಲ್ ಟ್ಯಾಗ್‌ಗಳನ್ನು ಬಳಸುತ್ತದೆ. ದುಡುಕಿನ ಹಿನ್ನೆಲೆಯಿಂದ ಮಸುಕು ಬೂದು ಸರಾಸರಿ ಕೆಲವೊಮ್ಮೆ \"ನ್ಯೂಟ್ರಲ್\" ವಲಯದಲ್ಲಿ ಬೀಳಬಹುದು clash ಬದಲು. ಅಂಕಗಳನ್ನು ಮಾರ್ಗದರ್ಶನವಾಗಿ ಮಾತ್ರ ನೋಡಿ; ನಿಜವಾದ ಅಲಂಕಾರಕ್ಕೆ ನಿಮ್ಮ ಕಣ್ಣನ್ನು ನಂಬಿ.";


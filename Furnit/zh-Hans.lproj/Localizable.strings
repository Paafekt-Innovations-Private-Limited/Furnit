// FAQ - Room Creation
"faq.roomCreation" = "房间建立";
"faq.howToCreate" = "如何建立3D房间？";
"faq.howToCreateAnswer" = "点擊主画面左上角的照片图示，然后拍摄或选择房间照片。应用程式将自动从照片产生3D模型。";
"faq.bestPhotos" = "什么样的照片效果最好？";
"faq.bestPhotosAnswer" = "为获得最佳效果，请在光线充足的环境下拍摄，并保持相机水平。尽量拍摄整个房间，包括地板、墙壁和天花板边緣。避免模糊或昏暗的照片。";
"faq.generationFailing" = "为什么我的房间产生失败？";
"faq.generationFailingAnswer" = "如果照片太暗、模糊或没有显示足够的房间特征，房间产生可能会失败。请尝试在更好的光线下以更宽的角度拍摄新照片。";
"faq.howManyRooms" = "我可以建立多少个房间？";
"faq.howManyRoomsAnswer" = "你最多可以建立10个房间。删除舊房间以腾出空间。房间数量显示在主画面顶部。";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "家具分割";
"faq.whatIsSegmentation" = "什么是家具分割？";
"faq.whatIsSegmentationAnswer" = "家具分割使用AI识别和分离照片中的家具，让你看到每件家具在3D房间中的效果。";
"faq.howToSegment" = "如何从照片中分割家具？";
"faq.howToSegmentAnswer" = "检视3D房间时，点擊家具图示存取分割功能。选择包含家具的照片，应用程式将自动侦测并撷取家具。";
"faq.notDetected" = "为什么我的家具没有被侦测到？";
"faq.notDetectedAnswer" = "家具侦测在清晰、光线充足且家具明显可见的照片中效果最佳。确保家具没有被部分遮挡或与背景融合。";
"faq.multiplePieces" = "我可以分割多件家具嗎？";
"faq.multiplePiecesAnswer" = "可以！AI可以在单张照片中侦测多件家具。每个侦测到的物品将单獨显示，供你选择使用。";

// FAQ - 3D Room & Fitment
"faq.roomFitment" = "3D房间与布置";
"faq.howToView" = "如何检视我的3D房间？";
"faq.howToViewAnswer" = "点擊主画面上的任何房间以开启3D检视器。你可以使用触控手势旋转、缩放和平移房间。";
"faq.howToPlace" = "如何在房间中放置家具？";
"faq.howToPlaceAnswer" = "分割家具后，点擊家具将其加入房间。然后你可以拖拽定位、捏合调整大小、旋转调整方向。";
"faq.sampleRoom" = "我可以使用范例房间嗎？";
"faq.sampleRoomAnswer" = "可以！应用程式提供范例房间供你体验。从探索部分存取它們，无需先建立自己的房间即可尝试家具布置。";
"faq.accuracy" = "3D模型有多准确？";
"faq.accuracyAnswer" = "3D模型能很好地近似你的房间布局。为获得最佳准确度，请确保原始照片清晰地捕捉房间尺寸，包括可见的角落和边緣。";
"faq.adjustDimensions" = "我可以调整房间尺寸嗎？";
"faq.adjustDimensionsAnswer" = "可以，进入设定并找到房间尺寸选項，你可以微调产生房间的大小和比例。";


<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:ignore="MergeRootFrame">

    <!-- Full-screen 3D View -->
    <io.github.sceneview.SceneView
        android:id="@+id/sceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Bar - Rounded dark container matching iOS (overlay on 3D view) -->
    <LinearLayout
        android:id="@+id/topBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/rounded_dark_bar"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Back button (circle) -->
            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back_arrow"
                android:background="@drawable/circle_button_dark"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:contentDescription="Back" />

            <!-- Title -->
            <TextView
                android:id="@+id/modelTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="3D Room View"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

            <!-- Help button (circle) -->
            <ImageButton
                android:id="@+id/helpButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_help"
                android:background="@drawable/circle_button_dark"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Help" />

            <!-- Save button (circle) - down arrow -->
            <ImageButton
                android:id="@+id/saveButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_download"
                android:background="@drawable/circle_button_dark"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Save Room" />

            <!-- Share button (circle) - up arrow -->
            <ImageButton
                android:id="@+id/shareButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_share"
                android:background="@drawable/circle_button_dark"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Share Room" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:elevation="8dp"
        android:visibility="visible" />

    <!-- Bottom Controls temporarily removed until camera issue is sorted -->

</FrameLayout>

// FAQ - AI Features (added)
"faq.aiFeatures" = "AI அம்சங்கள்";
"faq.whatIsBrainIcon" = "மூளை ஐகான் என்ன செய்கிறது?";
"faq.whatIsBrainIconAnswer" = "மூளை ஐகான் SmartyPants-ஐ செயல்படுத்துகிறது - AI-இயக்கும் பொருள் கண்டறிதல் அம்சம். இது நிகழ்நேரத்தில் தளபாடங்கள் மற்றும் பொருட்களை அடையாளம் காண உங்கள் கேமராவைப் பயன்படுத்துகிறது, கண்டறியப்பட்ட உருப்படிகளைச் சுற்றி லேபிள்கள் மற்றும் பவுண்டிங் பாக்ஸ்களைக் காட்டுகிறது.";
"faq.howToScreenshot" = "ஸ்கிரீன்ஷாட் எப்படி எடுப்பது?";
"faq.howToScreenshotAnswer" = "SmartyPants செயலில் இருக்கும்போது (மூளை ஐகான் பச்சை), கீழே-வலதுபுறத்தில் பகிர் ஐகான் தோன்றும். AI கண்டறிதல்களுடன் பார்வையின் ஸ்கிரீன்ஷாட்டை உங்கள் புகைப்பட நூலகத்தில் சேமிக்க அதைத் தட்டவும்.";
"faq.howToSaveRoom" = "அறையை எப்படி சேமிப்பது?";
"faq.howToSaveRoomAnswer" = "3D அறையை உருவாக்கிய பிறகு, தனிப்பயன் பெயருடன் சேமிக்க கருவிப்பட்டியில் சேமி ஐகானை (பதிவிறக்க அம்பு) தட்டவும். சேமிக்கப்படாத அறைகள் பின் தட்டும்போது நீக்கப்படும்.";

// FAQ - 3D Room Controls (added)
"faq.roomControls" = "3D அறை கட்டுப்பாடுகள்";
"faq.howToNavigate" = "அறைக்குள் எப்படி செல்வது?";
"faq.howToNavigateAnswer" = "திரையின் கீழ் மையத்தில் உள்ள ஜாய்ஸ்டிக்கைப் பயன்படுத்தி நகரவும். அறை வழியாக பறக்க எந்த திசையிலும் இழுக்கவும். கேமரா நிலையை மீட்டமைக்க ரீசென்டர் பொத்தானை (வியூஃபைண்டர் ஐகான்) தட்டவும்.";
"faq.whatDoArrowsDo" = "அம்பு பொத்தான்கள் என்ன செய்கின்றன?";
"faq.whatDoArrowsDoAnswer" = "3D காட்சியின் பக்கத்திலுள்ள அம்பு பொத்தான்கள் கேமராவை நகர்த்தும்: மேலும் கீழும் காட்சி உயரத்தை மாற்றும்; இடமும் வலமும் பான் செய்யும். அறையை சுற்றி சுழற்ற திரையில் இழுக்கலாம், காட்சியை மீட்டமைக்க ரீசென்டர் பொத்தானை (வியூஃபைண்டர் ஐகான்) பயன்படுத்தலாம்.";
"faq.whatIsMemoryDisplay" = "MB எண் என்ன அர்த்தம்?";
"faq.whatIsMemoryDisplayAnswer" = "அறைகளில் காட்டப்படும் MB (மெகாபைட்கள்) கோப்பு அளவைக் குறிக்கிறது. இது சேமிப்பகத்தை நிர்வகிக்க உதவுகிறது. அனைத்து அறைகளும் பயன்படுத்தும் மொத்த சேமிப்பகம் முகப்புத் திரையின் மேலே காட்டப்படும்.";


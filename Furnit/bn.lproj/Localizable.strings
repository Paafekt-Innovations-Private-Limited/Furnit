// FAQ overrides
"help.measurementAccuracyTitle" = "মাপজোক সংক্রান্ত নোটিশ";
"help.measurementAccuracyBody" = "AR depth সমর্থনহীন ফোনেও রুম ও ফার্নিচারের প্রিভিউ দেখা যাবে, তবে রুমের মাপ এবং বিশেষ করে ফার্নিচারের মাপ কেবল আনুমানিক হবে।";
"faq.whatIsBrainIconAnswer" = "ব্রেইন আইকন SmartyPants identify mode শুরু করে। এটি লাইভ ক্যামেরা দিয়ে ফার্নিচার ও বস্তু খুঁজে, লেবেল ও বক্স দেখায়, এবং Segment চাপার আগে এক বা একাধিক লেবেল নির্বাচন করতে দেয়।";
"faq.howToSegmentAnswer" = "রুম ভিউয়ারে ব্রেইন আইকনে ট্যাপ করুন, ক্যামেরা ফার্নিচারের দিকে ধরুন, এক বা একাধিক শনাক্ত লেবেল বেছে নিন, তারপর Segment ট্যাপ করুন। লাইভ শনাক্তকরণে ফিরতে Stop ট্যাপ করুন।";
"faq.accuracyAnswer" = "3D রুমটি একটিমাত্র ছবির ভিত্তিতে একটি অনুমান। রুমের মাপ দিকনির্দেশনা হিসেবে কাজে লাগতে পারে, তবে তা জরিপ-মানের নয়। ফার্নিচার মাপ AR বা depth সমর্থিত ফোনে সবচেয়ে নির্ভরযোগ্য।";
"faq.adjustDimensionsAnswer" = "AI-জেনারেটেড SHARP রুমে সরাসরি নয়। বর্তমান আনুমানিক প্রস্থ, উচ্চতা ও গভীরতা দেখতে রুম ভিউয়ারের রুলার ব্যবহার করুন। ভাল ফলের জন্য কোণা দেখা যায় এমন পরিষ্কার রুমের ছবি তুলুন; ম্যানুয়াল রুম আপনার সেট করা সীমানা অনুসরণ করে।";
"faq.arAssistedSizingAnswer" = "প্রথমে ব্রেইন আইকনে ট্যাপ করে শনাক্ত আইটেম নির্বাচন করুন, তারপর Segment ট্যাপ করুন। রুমের অনুপাতে সাইজ চাইলে sizing control ব্যবহার করুন। AR/depth সমর্থিত ফোনে অ্যাপ লাইভ ক্যামেরা depth ব্যবহার করে আরও বাস্তবসম্মত ফার্নিচার সাইজ দেয়; depth না থাকলে মাপ আনুমানিক।";
"faq.measurementPillAnswer" = "ফার্নিচার সাইজের ছোট পিলটি তখনই দেখা যায় যখন sizing mode চালু থাকে এবং অ্যাপের কাছে ব্যবহারযোগ্য লাইভ উচ্চতার অনুমান থাকে। রুলার বাটন একটি ছোট কার্ডে বর্তমান রুমের প্রস্থ, উচ্চতা ও গভীরতা দেখায়। non-AR ফোনে এই মানগুলো বিশেষ করে ফার্নিচারের ক্ষেত্রে কম নির্ভরযোগ্য।";
"faq.resetOverlayScaleAnswer" = "এখন আর কোনো overflow menu নেই। ওভারলে ভুল দেখালে ব্রেইন আইকন বন্ধ করে আবার চালু করুন, অথবা pinch করে ফার্নিচারের আকার হাতে ঠিক করুন।";

"faq.pinchOverlaySize" = "সেগমেন্ট করা ফার্নিচারকে পিঞ্চ করলে কী হয়?";
"faq.pinchOverlaySizeAnswer" = "পিঞ্চ করলে ফার্নিচার ওভারলে বড় বা ছোট হয়। যদি sizing mode চালু থাকে এবং Furni pill দেখা যায়, তাহলে সেই pill-এ রুম অনুযায়ী বর্তমান resized ফার্নিচারের মাপ আপডেট হবে। sizing mode বন্ধ থাকলে, পিঞ্চ শুধু স্ক্রিনে ওভারলের দৃশ্যমান আকার বদলাবে।";


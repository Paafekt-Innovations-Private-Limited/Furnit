<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark theme matching iOS -->
    <style name="Theme.Furnit" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">#AF52DE</item>
        <item name="colorPrimaryVariant">#9B47C5</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <!-- Secondary/accent colors -->
        <item name="colorSecondary">#34C759</item>
        <item name="colorSecondaryVariant">#2DB84D</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <!-- Background colors matching iOS dark theme -->
        <item name="android:colorBackground">#1C1C1E</item>
        <item name="colorSurface">#2C2C2E</item>
        <item name="colorOnSurface">@android:color/white</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">#1C1C1E</item>
        <item name="android:navigationBarColor">#1C1C1E</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>

// FAQ overrides
"help.measurementAccuracyTitle" = "تنبيه القياس";
"help.measurementAccuracyBody" = "يمكن للهواتف التي لا تدعم عمق AR معاينة الغرف والأثاث، لكن قياسات الغرفة وخصوصاً الأثاث ستكون تقريبية فقط.";
"faq.whatIsBrainIconAnswer" = "تبدأ أيقونة الدماغ وضع التعرف في SmartyPants. تستخدم الكاميرا الحية للعثور على الأثاث والأجسام، وتعرض التسميات والمربعات، وتتيح لك اختيار تسمية واحدة أو أكثر قبل الضغط على Segment.";
"faq.howToSegmentAnswer" = "في عارض الغرفة، اضغط أيقونة الدماغ ووجّه الكاميرا نحو الأثاث، ثم اضغط تسمية واحدة أو أكثر لاختيارها، وبعد ذلك اضغط Segment. اضغط Stop للعودة إلى التعرف المباشر.";
"faq.accuracyAnswer" = "الغرفة ثلاثية الأبعاد هي تقدير من صورة واحدة. قد تكون أبعاد الغرفة مفيدة كإرشاد، لكنها ليست قياسات دقيقة. قياس الأثاث يكون أوثق على الهواتف التي تدعم AR أو العمق.";
"faq.adjustDimensionsAnswer" = "ليس مباشرة في غرف SHARP المولدة بالذكاء الاصطناعي. استخدم المسطرة داخل عارض الغرفة لعرض تقدير العرض والارتفاع والعمق الحالي. ولنتائج أفضل التقط صورة واضحة للغرفة مع زوايا ظاهرة؛ أما الغرف اليدوية فتتبع الحدود التي تحددها.";
"faq.arAssistedSizingAnswer" = "اضغط أولاً أيقونة الدماغ واختر العناصر المكتشفة، ثم اضغط Segment. استخدم أداة الحجم عندما تريد قياساً نسبة إلى الغرفة. على الهواتف التي تدعم AR أو العمق يستخدم التطبيق عمق الكاميرا الحي لحجم أثاث أكثر واقعية؛ وبدون العمق تكون قياسات الأثاث تقريبية.";
"faq.measurementPillAnswer" = "تظهر قراءة حجم الأثاث فقط عند تفعيل وضع تغيير الحجم وعندما يحصل التطبيق على تقدير حي صالح للارتفاع. ويعرض زر المسطرة العرض والارتفاع والعمق الحاليين للغرفة في بطاقة صغيرة. وعلى الهواتف غير الداعمة لـ AR تكون هذه القراءات أقل موثوقية، خصوصاً للأثاث.";
"faq.resetOverlayScaleAnswer" = "لم تعد هناك قائمة إضافية الآن. إذا بدت طبقة الأثاث غير صحيحة فأوقف أيقونة الدماغ ثم شغّلها مرة أخرى، أو استخدم حركة القرص لضبط الحجم يدوياً.";

"faq.pinchOverlaySize" = "ماذا يحدث عندما أقرّب أو أبعّد الأثاث المُقسَّم بإصبعيّ؟";
"faq.pinchOverlaySizeAnswer" = "التقريب أو الإبعاد يجعل طبقة الأثاث أكبر أو أصغر. إذا كان وضع تحديد الحجم مفعّلًا وكانت شارة Furni ظاهرة، فستتحدّث هذه الشارة إلى التقدير الحالي لحجم الأثاث بعد تغييره بالنسبة إلى الغرفة. وإذا كان وضع تحديد الحجم متوقفًا، فسيغيّر التقريب شكل الطبقة على الشاشة فقط.";


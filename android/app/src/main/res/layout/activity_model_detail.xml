<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:ignore="MergeRootFrame">

    <!-- Full-screen 3D View -->
    <io.github.sceneview.SceneView
        android:id="@+id/sceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Bar - Rounded dark container matching iOS (overlay on 3D view) -->
    <LinearLayout
        android:id="@+id/topBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/rounded_dark_bar"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Back button (circle) -->
            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back_arrow"
                android:background="@drawable/circle_button_dark"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:contentDescription="Back" />

            <!-- Title -->
            <TextView
                android:id="@+id/modelTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="3D Room View"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

            <!-- Help button (circle) -->
            <ImageButton
                android:id="@+id/helpButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_help"
                android:background="@drawable/circle_button_dark"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Help" />

            <!-- Save button (circle) - down arrow -->
            <ImageButton
                android:id="@+id/saveButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_download"
                android:background="@drawable/circle_button_dark"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Save Room" />

            <!-- Share button (circle) - up arrow -->
            <ImageButton
                android:id="@+id/shareButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_share"
                android:background="@drawable/circle_button_dark"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Share Room" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:elevation="8dp"
        android:visibility="visible" />

    <!-- Bottom Controls matching iOS - overlay on 3D view -->
    <FrameLayout
        android:id="@+id/bottomControlsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:elevation="8dp">

        <!-- Brain icon (left) for FurnitureFit -->
        <ImageButton
            android:id="@+id/brainButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="start|bottom"
            android:src="@drawable/ic_brain"
            android:background="@drawable/circle_button_blue"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="AI Segment Furniture" />

        <!-- Joystick (center) for camera control -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:orientation="vertical"
            android:gravity="center">

            <com.furnit.android.views.JoystickView
                android:id="@+id/joystickView"
                android:layout_width="100dp"
                android:layout_height="100dp" />

            <!-- Orientation label below joystick -->
            <LinearLayout
                android:id="@+id/orientationLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/rounded_label_dark"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/orientationSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="held vertically"
                    android:textSize="12sp"
                    android:textColor="@android:color/white" />

                <TextView
                    android:id="@+id/orientationTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Portrait"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- Camera/Screenshot icon (right) -->
        <ImageButton
            android:id="@+id/screenshotButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="end|bottom"
            android:src="@drawable/ic_camera"
            android:background="@drawable/circle_button_blue"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="Take Screenshot" />
    </FrameLayout>

</FrameLayout>

// FAQ - Room Creation
"faq.roomCreation" = "Creación de habitaciones";
"faq.howToCreate" = "¿Cómo creo una habitación 3D?";
"faq.howToCreateAnswer" = "Tap the photo icon in the top-left corner of the home screen, then take or select a photo of your room. You'll see two options to choose from for creating your 3D room.";
"faq.twoMethods" = "What are the two room creation options?";
"faq.twoMethodsAnswer" = "When you select a photo, you can choose between: 1) AI-Powered 3D Room - automatically creates a realistic 3D room using artificial intelligence, or 2) Manual Setup - lets you draw the room boundaries yourself for more control.";
"faq.whatIsAIRoom" = "What is AI-Powered 3D Room?";
"faq.whatIsAIRoomAnswer" = "This option uses smart technology to automatically turn your photo into a 3D room you can walk through. Just pick a photo and the app does the rest - no drawing or adjusting needed. It works like magic!";
"faq.whatIsManualRoom" = "What is Manual Setup?";
"faq.whatIsManualRoomAnswer" = "With Manual Setup, you draw the outline of your room's walls on the photo. This gives you more control over exactly how the 3D room looks. It's great when you want to fine-tune the room shape yourself.";
"faq.whichMethodBetter" = "Which method should I choose?";
"faq.whichMethodBetterAnswer" = "Try AI-Powered first - it's faster and works great for most rooms. If the result doesn't look quite right, use Manual Setup to draw the walls exactly where you want them. You can always try both and see which one you prefer!";
"faq.bestPhotos" = "¿Qué tipo de fotos funcionan mejor?";
"faq.bestPhotosAnswer" = "Para mejores resultados, toma fotos con buena iluminación y la cámara en horizontal. Intenta capturar toda la habitación incluyendo suelos, paredes y bordes del techo. Evita fotos borrosas u oscuras.";
"faq.generationFailing" = "¿Por qué falla la generación de mi habitación?";
"faq.generationFailingAnswer" = "La generación de habitación puede fallar si la foto es demasiado oscura, borrosa o no muestra suficientes características de la habitación. Intenta tomar una nueva foto con mejor iluminación y un ángulo más amplio.";
"faq.howManyRooms" = "¿Cuántas habitaciones puedo crear?";
"faq.howManyRoomsAnswer" = "Puedes crear hasta 10 habitaciones. Elimina habitaciones antiguas para hacer espacio para nuevas. El recuento de habitaciones se muestra en la parte superior de tu pantalla de inicio.";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "Segmentación de muebles";
"faq.whatIsSegmentation" = "¿Qué es la segmentación de muebles?";
"faq.whatIsSegmentationAnswer" = "La segmentación de muebles usa IA para identificar y separar muebles en tus fotos, permitiéndote ver cómo cada pieza encajaría en tu habitación 3D.";
"faq.howToSegment" = "¿Cómo segmento muebles de una foto?";
"faq.howToSegmentAnswer" = "Al ver tu habitación 3D, toca el icono de muebles para acceder a la función de segmentación. Selecciona una foto con muebles y la aplicación detectará y extraerá automáticamente los elementos de mobiliario.";
"faq.notDetected" = "¿Por qué no se detectan mis muebles?";
"faq.notDetectedAnswer" = "La detección de muebles funciona mejor con fotos claras y bien iluminadas donde los muebles son claramente visibles. Asegúrate de que los muebles no estén parcialmente ocultos o se confundan con el fondo.";
"faq.multiplePieces" = "¿Puedo segmentar múltiples muebles?";
"faq.multiplePiecesAnswer" = "¡Sí! La IA puede detectar múltiples muebles en una sola foto. Cada elemento detectado se mostrará por separado para que puedas elegir cuáles usar.";

// FAQ - 3D Room & Fitment
"faq.roomFitment" = "Habitación 3D y colocación";
"faq.howToView" = "¿Cómo veo mi habitación 3D?";
"faq.howToViewAnswer" = "Toca cualquier habitación en tu pantalla de inicio para abrir el visor 3D. Puedes rotar, hacer zoom y desplazarte por la habitación usando gestos táctiles.";
"faq.howToPlace" = "¿Cómo coloco muebles en mi habitación?";
"faq.howToPlaceAnswer" = "Después de segmentar muebles, toca el mueble para añadirlo a tu habitación. Luego puedes arrastrarlo para posicionarlo, pellizcar para cambiar el tamaño y rotar para ajustar su orientación.";
"faq.sampleRoom" = "¿Puedo usar una habitación de ejemplo en lugar de la mía?";
"faq.sampleRoomAnswer" = "¡Sí! La aplicación proporciona habitaciones de ejemplo para experimentar. Accede a ellas desde la sección Explorar para probar la colocación de muebles sin crear primero tu propia habitación.";
"faq.accuracy" = "¿Qué tan preciso es el modelo 3D?";
"faq.accuracyAnswer" = "El modelo 3D proporciona una buena aproximación del diseño de tu habitación. Para mayor precisión, asegúrate de que tu foto original capture claramente las dimensiones de la habitación con esquinas y bordes visibles.";
"faq.adjustDimensions" = "¿Puedo ajustar las dimensiones de la habitación?";
"faq.adjustDimensionsAnswer" = "Sí, ve a Ajustes y busca las opciones de Dimensiones de habitación donde puedes afinar el tamaño y proporciones de tu habitación generada.";


<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.ar" android:required="false" />
    <uses-feature android:name="android.hardware.vulkan.version" android:required="false" />

    <application
        android:name=".FurnitApplication"
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:label="Furnit"
        android:supportsRtl="true"
        android:theme="@style/Theme.Furnit">

        <!-- ExecuTorch AAR at build time: true = etVulkan flavor (executorch-android-vulkan), false = etCpu (executorch-android / XNNPACK). -->
        <meta-data
            android:name="com.furnit.executorch.USE_VULKAN_AAR"
            android:value="${executorchVulkanAar}" />

        <!-- ARCore optional: app installs on non-AR devices; ArMeasureActivity checks support at runtime. -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="optional" />

        <!-- Auth Activities -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".auth.OTPVerificationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize|stateVisible" />

        <!-- Main Activities -->
        <activity android:name=".ContentActivity" android:exported="false" />
        <activity android:name=".ARActivity" android:exported="false" />
        <activity android:name=".ModelViewerActivity" android:exported="false" />
        <activity android:name=".FurnitureFitActivity" android:exported="false" />
        <activity android:name=".MainActivity" android:exported="false" />
        <activity
            android:name=".ModelDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Furnit.FullScreen" />
        <activity android:name=".SinglePhotoRoomActivity" android:exported="false" />
        <activity android:name=".SettingsImageScanActivity" android:exported="false" />
        <activity android:name=".RoomBoundaryActivity" android:exported="false" />
        <activity
            android:name=".RoomViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.Furnit.FullScreen" />
        <activity
            android:name=".SharpRoomActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:theme="@style/Theme.Furnit.FullScreen" />
        <activity
            android:name=".ArMeasureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Furnit.FullScreen" />
        <activity
            android:name=".ArDepthPhotoCaptureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Furnit.FullScreen" />
        <activity
            android:name=".GLBRoomActivity"
            android:exported="false"
            android:theme="@style/Theme.Furnit.FullScreen" />
        <activity android:name=".SettingsActivity" android:exported="false" />
        <activity android:name=".CreditsActivity" android:exported="false" />
        <activity android:name=".LicensesActivity" android:exported="false" />
        <activity android:name=".HelpActivity" android:exported="false" />
        <activity
            android:name=".CrashReportActivity"
            android:exported="false"
            android:process=":crash"
            android:theme="@style/Theme.Furnit.CrashDialog" />

        <!-- FileProvider for camera photos -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>

// FAQ - Room Creation
"faq.roomCreation" = "அறை உருவாக்கம்";
"faq.howToCreate" = "3D அறையை எப்படி உருவாக்குவது?";
"faq.howToCreateAnswer" = "முகப்பு திரையின் மேல்-இடது மூலையில் உள்ள புகைப்பட ஐகானைத் தட்டவும், பின்னர் உங்கள் அறையின் புகைப்படம் எடுக்கவும் அல்லது தேர்ந்தெடுக்கவும். உங்கள் 3D அறையை உருவாக்க இரண்டு விருப்பங்களைக் காண்பீர்கள்.";
"faq.howToTakePhoto" = "அறை உருவாக்க புகைப்படம் எப்படி எடுப்பது?";
"faq.howToTakePhotoAnswer" = "நேரடியாக புகைப்படம் எடுக்க முகப்பு திரையில் கேமரா ஐகானைத் தட்டவும். நிலையான (1x) அல்லது அகலக்கோண (0.5x அல்ட்ரா-வைட்) லென்ஸைத் தேர்வு செய்யலாம். உங்கள் சாதனத்தை நிலையாகப் பிடித்து, படப்பிடிப்பு பொத்தானைத் தட்டவும். புகைப்படம் உங்கள் 3D அறையை உருவாக்க பயன்படுத்தப்படும்.";
"faq.depthAwareRoomPhoto" = "பயன்பாட்டில் புகைப்படம் எடுப்பது உதவுமா?";
"faq.depthAwareRoomPhotoAnswer" = "ஆம். ஆதரவுள்ள சாதனங்களில், கேலரிக்கு பதிலாக Take a photo ஆழம்-விழிப்புணர்வு கேமராவைப் பயன்படுத்துகிறது (கிடைத்தால்), இது 3D அறையை மேம்படுத்த உதவும்.";
"faq.twoMethods" = "அறை உருவாக்கத்திற்கான இரண்டு விருப்பங்கள் என்ன?";
"faq.twoMethodsAnswer" = "புகைப்படம் தேர்ந்தெடுக்கும்போது நீங்கள் தேர்வு செய்யலாம்: 1) AI இயக்கப்பட்ட 3D அறை - செயற்கை நுண்ணறிவைப் பயன்படுத்தி யதார்த்த 3D அறையை தானாக உருவாக்குகிறது, அல்லது 2) கைமுறை அமைப்பு - அதிக கட்டுப்பாட்டிற்காக அறை எல்லைகளை நீங்களே வரையலாம்.";
"faq.whatIsAIRoom" = "AI இயக்கப்பட்ட 3D அறை என்றால் என்ன?";
"faq.whatIsAIRoomAnswer" = "இந்த விருப்பம் உங்கள் படத்தை நீங்கள் நடக்கக்கூடிய 3D அறையாக தானாக மாற்ற ஸ்மார்ட் தொழில்நுட்பத்தைப் பயன்படுத்துகிறது. ஒரு படத்தைத் தேர்ந்தெடுத்தால் பயன்பாடு மீதியைச் செய்யும் - வரைதல் அல்லது சரிசெய்தல் தேவையில்லை. மந்திரம் போல வேலை செய்கிறது!";
"faq.whatIsManualRoom" = "கைமுறை அமைப்பு என்றால் என்ன?";
"faq.whatIsManualRoomAnswer" = "கைமுறை அமைப்பில், புகைப்படத்தில் உங்கள் அறை சுவர்களின் கோடுகளை வரையவும். 3D அறை சரியாக எப்படி இருக்கும் என்பதில் அதிக கட்டுப்பாடு தரும். அறை வடிவத்தை நீங்களே சரிசெய்ய விரும்பும்போது சிறந்தது.";
"faq.whichMethodBetter" = "நான் எந்த முறையை தேர்வு செய்ய வேண்டும்?";
"faq.whichMethodBetterAnswer" = "முதலில் AI இயக்கப்பட்டதை முயற்சிக்கவும் - வேகமானது, பெரும்பாலான அறைகளுக்கு நன்றாக வேலை செய்கிறது. முடிவு சரியாக இல்லை என்றால், சுவர்களை நீங்கள் விரும்பும் இடத்தில் வரைய கைமுறை அமைப்பைப் பயன்படுத்தவும். இரண்டையும் முயற்சித்து ஏது பிடிக்கும் என்று பாருங்கள்!";
"faq.bestPhotos" = "எந்த வகையான புகைப்படங்கள் சிறப்பாக செயல்படும்?";
"faq.bestPhotosAnswer" = "சிறந்த முடிவுகளுக்கு, நல்ல வெளிச்சத்தில் சாதனத்தை நிலையாக வைத்து புகைப்படங்கள் எடுக்கவும். தரைகள், சுவர்கள் மற்றும் கூரை விளிம்புகள் உட்பட முழு அறையையும் படம்பிடிக்க முயற்சிக்கவும். மங்கலான அல்லது இருண்ட புகைப்படங்களைத் தவிர்க்கவும்.";
"faq.generationFailing" = "என் அறை உருவாக்கம் ஏன் தோல்வியடைகிறது?";
"faq.generationFailingAnswer" = "புகைப்படம் மிகவும் இருட்டாகவோ, மங்கலாகவோ, அல்லது போதுமான அறை அம்சங்களைக் காட்டவில்லை என்றால் அறை உருவாக்கம் தோல்வியடையலாம். சிறந்த வெளிச்சம் மற்றும் அகலமான கோணத்துடன் புதிய புகைப்படம் எடுக்க முயற்சிக்கவும்.";
"faq.howManyRooms" = "எத்தனை அறைகளை உருவாக்க முடியும்?";
"faq.howManyRoomsAnswer" = "நீங்கள் 1000 அறைகள் வரை உருவாக்கலாம். புதியவற்றுக்கு இடம் உருவாக்க பழைய அறைகளை நீக்கவும். அறை எண்ணிக்கை மற்றும் பயன்படுத்திய சேமிப்பு முகப்புத் திரையின் மேலே காட்டப்படும்.";


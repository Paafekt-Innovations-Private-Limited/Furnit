"faq.howToTakePhotoAnswer" = "നേരിട്ട് ഫോട്ടോ എടുക്കാൻ ഹോം സ്ക്രീനിൽ ക്യാമറ ഐക്കൺ ടാപ്പ് ചെയ്യുക. സ്റ്റാൻഡേർഡ് (1x) അല്ലെങ്കിൽ വൈഡ് ആംഗിൾ (0.5x അൾട്രാ-വൈഡ്) ലെൻസ് നിങ്ങൾക്ക് തിരഞ്ഞെടുക്കാം. നിങ്ങളുടെ ഉപകരണം സ്ഥിരമായി പിടിച്ച് ക്യാപ്ചർ ബട്ടൺ ടാപ്പ് ചെയ്യുക. ഫോട്ടോ നിങ്ങളുടെ 3D മുറി സൃഷ്ടിക്കാൻ ഉപയോഗിക്കും.";
"faq.depthAwareRoomPhoto" = "ആപ്പിൽ ഫോട്ടോ എടുക്കുന്നത് ഗുണനിലവാരത്തിന് സഹായിക്കുമോ?";
"faq.depthAwareRoomPhotoAnswer" = "അതെ. പിന്തുണയുള്ള ഉപകരണങ്ങളിൽ, ഗാലറിക്ക് പകരം Take a photo ആഴം-അവബോധ ക്യാമറ ഉപയോഗിക്കുന്നു (ലഭ്യമെങ്കിൽ), ഇത് 3D മുറി മെച്ചപ്പെടുത്താം.";
"faq.twoMethods" = "മുറി സൃഷ്ടിക്കാനുള്ള രണ്ട് ഓപ്ഷനുകൾ എന്താണ്?";
"faq.twoMethodsAnswer" = "ഒരു ഫോട്ടോ തിരഞ്ഞെടുക്കുമ്പോൾ നിങ്ങൾക്ക് തിരഞ്ഞെടുക്കാം: 1) AI-നിയന്ത്രിത 3D മുറി - കൃത്രിമ ബുദ്ധി ഉപയോഗിച്ച് യഥാർത്ഥ 3D മുറി സ്വയമേവ സൃഷ്ടിക്കുന്നു, അല്ലെങ്കിൽ 2) മാനുവൽ സെറ്റപ്പ് - കൂടുതൽ നിയന്ത്രണത്തിനായി മുറി അതിർത്തികൾ നിങ്ങൾ സ്വയം വരയ്ക്കാം.";
"faq.whatIsAIRoom" = "AI-നിയന്ത്രിത 3D മുറി എന്താണ്?";
"faq.whatIsAIRoomAnswer" = "നിങ്ങളുടെ ഫോട്ടോ സ്വയം 3D മുറിയാക്കി മാറ്റാൻ ഈ ഓപ്ഷൻ സ്മാർട്ട് ടെക്നോളജി ഉപയോഗിക്കുന്നു. ഒരു ഫോട്ടോ തിരഞ്ഞെടുക്കുക, ബാക്കി ആപ്പ് ചെയ്യും - വരയ്ക്കലോ ക്രമീകരണമോ ആവശ്യമില്ല. മാന്ത്രികം പോലെ പ്രവർത്തിക്കുന്നു!";
"faq.whatIsManualRoom" = "മാനുവൽ സെറ്റപ്പ് എന്താണ്?";
"faq.whatIsManualRoomAnswer" = "മാനുവൽ സെറ്റപ്പിൽ, ഫോട്ടോയിൽ നിങ്ങളുടെ മുറിയുടെ ചുവരുകളുടെ ഔട്ട്ലൈൻ വരയ്ക്കുക. 3D മുറി കൃത്യമായി എങ്ങനെ കാണപ്പെടുന്നു എന്നതിൽ കൂടുതൽ നിയന്ത്രണം നൽകുന്നു. മുറിയുടെ ആകൃതി സ്വയം ഫൈൻ-ട്യൂൺ ചെയ്യാൻ ആഗ്രഹിക്കുമ്പോൾ മികച്ചത്.";
"faq.whichMethodBetter" = "ഞാൻ ഏത് രീതി തിരഞ്ഞെടുക്കണം?";
"faq.whichMethodBetterAnswer" = "ആദ്യം AI-നിയന്ത്രിത പരീക്ഷിക്കുക - വേഗത്തിലും മിക്ക മുറികൾക്കും നന്നായി പ്രവർത്തിക്കുന്നു. ഫലം ശരിയായി കാണപ്പെടുന്നില്ലെങ്കിൽ, ചുവരുകൾ നിങ്ങൾക്ക് ആവശ്യമുള്ളിടത്ത് വരയ്ക്കാൻ മാനുവൽ സെറ്റപ്പ് ഉപയോഗിക്കുക. രണ്ടും പരീക്ഷിച്ച് ഏതാണ് ഇഷ്ടം എന്ന് കാണാം!";
"faq.bestPhotos" = "ഏത് തരം ഫോട്ടോകളാണ് നന്നായി പ്രവർത്തിക്കുന്നത്?";
"faq.bestPhotosAnswer" = "മികച്ച ഫലങ്ങൾക്ക്, നല്ല വെളിച്ചത്തിൽ ഉപകരണം സ്ഥിരമായി പിടിച്ച് ഫോട്ടോകൾ എടുക്കുക. തറ, ചുവരുകൾ, സീലിംഗ് അരികുകൾ എന്നിവയുൾപ്പെടെ മുഴുവൻ മുറിയും പിടിച്ചെടുക്കാൻ ശ്രമിക്കുക. മങ്ങിയ അല്ലെങ്കിൽ ഇരുണ്ട ഫോട്ടോകൾ ഒഴിവാക്കുക.";
"faq.generationFailing" = "എന്റെ മുറി ജനറേഷൻ എന്തുകൊണ്ട് പരാജയപ്പെടുന്നു?";
"faq.generationFailingAnswer" = "ഫോട്ടോ വളരെ ഇരുണ്ടതോ, മങ്ങിയതോ, അല്ലെങ്കിൽ മതിയായ മുറി സവിശേഷതകൾ കാണിക്കുന്നില്ലെങ്കിലോ മുറി ജനറേഷൻ പരാജയപ്പെട്ടേക്കാം. മെച്ചപ്പെട്ട വെളിച്ചവും വീതിയേറിയ കോണും ഉപയോഗിച്ച് പുതിയ ഫോട്ടോ എടുക്കാൻ ശ്രമിക്കുക.";
"faq.howManyRooms" = "എനിക്ക് എത്ര മുറികൾ സൃഷ്ടിക്കാം?";
"faq.howManyRoomsAnswer" = "നിങ്ങൾക്ക് 1000 മുറികൾ വരെ സൃഷ്ടിക്കാം. പുതിയതിനായി ഇടം ഉണ്ടാക്കാൻ പഴയ മുറികൾ ഇല്ലാതാക്കുക. മുറി എണ്ണവും ഉപയോഗിച്ച സ്റ്റോറേജും ഹോം സ്ക്രീനിന്റെ മുകളിൽ കാണാം.";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "ഫർണിച്ചർ സെഗ്മെന്റേഷൻ";
"faq.whatIsSegmentation" = "ഫർണിച്ചർ സെഗ്മെന്റേഷൻ എന്താണ്?";
"faq.whatIsSegmentationAnswer" = "ഫർണിച്ചർ സെഗ്മെന്റേഷൻ AI ഉപയോഗിച്ച് നിങ്ങളുടെ ഫോട്ടോകളിലെ ഫർണിച്ചർ തിരിച്ചറിയുകയും വേർതിരിക്കുകയും ചെയ്യുന്നു, ഓരോ കഷണവും നിങ്ങളുടെ 3D മുറിയിൽ എങ്ങനെ ചേരുമെന്ന് കാണാൻ അനുവദിക്കുന്നു.";
"faq.howToSegment" = "ഫോട്ടോയിൽ നിന്ന് ഫർണിച്ചർ എങ്ങനെ സെഗ്മെന്റ് ചെയ്യാം?";
"faq.howToSegmentAnswer" = "നിങ്ങളുടെ 3D മുറി കാണുമ്പോൾ, സെഗ്മെന്റേഷൻ ഫീച്ചർ ആക്സസ് ചെയ്യാൻ ഫർണിച്ചർ ഐക്കൺ ടാപ്പ് ചെയ്യുക. ഫർണിച്ചർ അടങ്ങിയ ഫോട്ടോ തിരഞ്ഞെടുക്കുക, ആപ്പ് സ്വയമേവ ഫർണിച്ചർ ഇനങ്ങൾ കണ്ടെത്തി വേർതിരിക്കും.";
"faq.notDetected" = "എന്റെ ഫർണിച്ചർ എന്തുകൊണ്ട് കണ്ടെത്തിയില്ല?";
"faq.notDetectedAnswer" = "ഫർണിച്ചർ കണ്ടെത്തൽ വ്യക്തമായ, നല്ല വെളിച്ചമുള്ള ഫോട്ടോകളിൽ ഫർണിച്ചർ വ്യക്തമായി കാണുമ്പോൾ നന്നായി പ്രവർത്തിക്കുന്നു. ഫർണിച്ചർ ഭാഗികമായി മൂടപ്പെട്ടിട്ടില്ലെന്നോ പശ്ചാത്തലവുമായി കലർന്നിട്ടില്ലെന്നോ ഉറപ്പാക്കുക.";
"faq.multiplePieces" = "ഒന്നിലധികം ഫർണിച്ചർ കഷണങ്ങൾ സെഗ്മെന്റ് ചെയ്യാമോ?";
"faq.multiplePiecesAnswer" = "അതെ! AI ക്ക് ഒരു ഫോട്ടോയിൽ ഒന്നിലധികം ഫർണിച്ചർ കഷണങ്ങൾ കണ്ടെത്താൻ കഴിയും. കണ്ടെത്തിയ ഓരോ ഇനവും പ്രത്യേകമായി പ്രദർശിപ്പിക്കും, ഏത് ഉപയോഗിക്കണമെന്ന് നിങ്ങൾ തിരഞ്ഞെടുക്കുന്നതിന്.";

// FAQ - 3D Room & Fitment
"faq.howToView" = "എന്റെ 3D മുറി എങ്ങനെ കാണാം?";
"faq.howToViewAnswer" = "3D വ്യൂവർ തുറക്കാൻ ഹോം സ്ക്രീനിലെ ഏതെങ്കിലും മുറി ടാപ്പ് ചെയ്യുക. ടച്ച് ജെസ്ച്ചറുകൾ ഉപയോഗിച്ച് മുറി തിരിക്കാനും സൂം ചെയ്യാനും പാൻ ചെയ്യാനും കഴിയും.";
"faq.howToPlace" = "എന്റെ മുറിയിൽ ഫർണിച്ചർ എങ്ങനെ വയ്ക്കാം?";
"faq.howToPlaceAnswer" = "ഫർണിച്ചർ സെഗ്മെന്റ് ചെയ്ത ശേഷം, നിങ്ങളുടെ മുറിയിലേക്ക് ചേർക്കാൻ ഒരു കഷണം ടാപ്പ് ചെയ്യുക. തുടർന്ന് സ്ഥാനത്തിന് വലിച്ചിടാനും, വലുപ്പം മാറ്റാൻ പിഞ്ച് ചെയ്യാനും, ദിശ ക്രമീകരിക്കാൻ തിരിക്കാനും കഴിയും.";
"faq.sampleRoom" = "എന്റേതിന് പകരം സാമ്പിൾ റൂം ഉപയോഗിക്കാമോ?";
"faq.sampleRoomAnswer" = "അതെ! ആപ്പ് പരീക്ഷിക്കാൻ സാമ്പിൾ റൂമുകൾ നൽകുന്നു. ആദ്യം നിങ്ങളുടെ സ്വന്തം മുറി സൃഷ്ടിക്കാതെ ഫർണിച്ചർ പ്ലേസ്മെന്റ് പരീക്ഷിക്കാൻ എക്സ്പ്ലോർ വിഭാഗത്തിൽ നിന്ന് അവ ആക്സസ് ചെയ്യുക.";
"faq.accuracy" = "3D മോഡൽ എത്ര കൃത്യമാണ്?";
"faq.accuracyAnswer" = "3D മോഡൽ നിങ്ങളുടെ മുറി ലേഔട്ടിന്റെ നല്ല ഏകദേശ കണക്ക് നൽകുന്നു. മികച്ച കൃത്യതയ്ക്ക്, നിങ്ങളുടെ യഥാർത്ഥ ഫോട്ടോ കാണാവുന്ന കോണുകളും അരികുകളും ഉള്ള മുറി അളവുകൾ വ്യക്തമായി പിടിച്ചെടുക്കുന്നുവെന്ന് ഉറപ്പാക്കുക.";
"faq.adjustDimensions" = "മുറി അളവുകൾ ക്രമീകരിക്കാമോ?";
"faq.adjustDimensionsAnswer" = "അതെ, ക്രമീകരണങ്ങളിലേക്ക് പോയി മുറി അളവ് ഓപ്ഷനുകൾ കണ്ടെത്തുക അവിടെ നിങ്ങൾക്ക് സൃഷ്ടിച്ച മുറിയുടെ വലുപ്പവും അനുപാതങ്ങളും ഫൈൻ-ട്യൂൺ ചെയ്യാം.";
"faq.furnitureMeasurements" = "ഫർണിച്ചറും അളവുകളും";
"faq.arAssistedSizing" = "AR-സഹായിത ഫർണിച്ചർ സൈസിംഗ് എന്താണ്?";
"faq.arAssistedSizingAnswer" = "ക്രമീകരണങ്ങളിൽ ഓണായാൽ, ആപ്പ് ക്യാമറാ ആഴവും വസ്തു കണ്ടെത്തലും സംയോജിപ്പിച്ച് നിങ്ങൾ അടുക്കുകയോ അകലുകയോ ചെയ്യുമ്പോൾ ഓവർലേ യഥാർത്ഥമായി സ്കേൽ ചെയ്യുന്നു. നല്ല വെളിച്ചവും വ്യക്തമായ ദൃശ്യവും മികച്ചതാണ്.";
"faq.measurementPill" = "ചെറിയ അളവ് വായന എന്താണ്?";

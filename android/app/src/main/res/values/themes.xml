<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark theme matching iOS -->
    <style name="Theme.Furnit" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">#AF52DE</item>
        <item name="colorPrimaryVariant">#9B47C5</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <!-- Secondary/accent colors -->
        <item name="colorSecondary">#34C759</item>
        <item name="colorSecondaryVariant">#2DB84D</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <!-- Background colors matching iOS dark theme -->
        <item name="android:colorBackground">#1C1C1E</item>
        <item name="colorSurface">#2C2C2E</item>
        <item name="colorOnSurface">@android:color/white</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">#1C1C1E</item>
        <item name="android:navigationBarColor">#1C1C1E</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Dark dialog theme matching iOS -->
    <style name="DarkDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:background">#3A3A3C</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">#EBEBF5</item>
        <item name="colorAccent">#0A84FF</item>
        <item name="buttonBarPositiveButtonStyle">@style/DarkDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DarkDialogButton</item>
    </style>

    <style name="DarkDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#0A84FF</item>
    </style>

    <!-- Full-screen theme for 3D viewer activities (matching iOS ignoresSafeArea) -->
    <style name="Theme.Furnit.FullScreen" parent="Theme.Furnit">
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>
    </style>
</resources>

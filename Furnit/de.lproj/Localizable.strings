// FAQ - Room Creation
"faq.roomCreation" = "Raumerstellung";
"faq.howToCreate" = "Wie erstelle ich einen 3D-Raum?";
"faq.howToCreateAnswer" = "Tippen Sie auf das Foto-Symbol in der oberen linken Ecke des Startbildschirms und nehmen Sie dann ein Foto Ihres Raums auf oder wählen Sie eines aus. Sie sehen zwei Optionen zur Auswahl für die Erstellung Ihres 3D-Raums.";
"faq.howToTakePhoto" = "Wie nehme ich ein Foto auf, um einen Raum zu erstellen?";
"faq.howToTakePhotoAnswer" = "Tippen Sie auf das Kamera-Symbol auf dem Startbildschirm, um direkt ein Foto aufzunehmen. Sie können zwischen Standard (1x) oder Weitwinkel (0.5x Ultra-Weitwinkel) Objektiv wählen. Halten Sie Ihr Gerät ruhig und tippen Sie auf die Aufnahmetaste. Das Foto wird dann verwendet, um Ihren 3D-Raum zu erstellen.";
"faq.twoMethods" = "What are the two room creation options?";
"faq.twoMethodsAnswer" = "When you select a photo, you can choose between: 1) AI-Powered 3D Room - automatically creates a realistic 3D room using artificial intelligence, or 2) Manual Setup - lets you draw the room boundaries yourself for more control.";
"faq.whatIsAIRoom" = "What is AI-Powered 3D Room?";
"faq.whatIsAIRoomAnswer" = "This option uses smart technology to automatically turn your photo into a 3D room you can walk through. Just pick a photo and the app does the rest - no drawing or adjusting needed. It works like magic!";
"faq.whatIsManualRoom" = "What is Manual Setup?";
"faq.whatIsManualRoomAnswer" = "With Manual Setup, you draw the outline of your room's walls on the photo. This gives you more control over exactly how the 3D room looks. It's great when you want to fine-tune the room shape yourself.";
"faq.whichMethodBetter" = "Which method should I choose?";
"faq.whichMethodBetterAnswer" = "Try AI-Powered first - it's faster and works great for most rooms. If the result doesn't look quite right, use Manual Setup to draw the walls exactly where you want them. You can always try both and see which one you prefer!";
"faq.bestPhotos" = "Welche Art von Fotos funktionieren am besten?";
"faq.bestPhotosAnswer" = "Für beste Ergebnisse machen Sie Fotos bei guter Beleuchtung mit waagerecht gehaltener Kamera. Versuchen Sie, den gesamten Raum einschließlich Böden, Wänden und Deckenkanten zu erfassen. Vermeiden Sie unscharfe oder dunkle Fotos.";
"faq.generationFailing" = "Warum schlägt meine Raumerstellung fehl?";
"faq.generationFailingAnswer" = "Die Raumerstellung kann fehlschlagen, wenn das Foto zu dunkel, unscharf ist oder nicht genügend Raummerkmale zeigt. Versuchen Sie, ein neues Foto mit besserer Beleuchtung und einem weiteren Winkel aufzunehmen.";
"faq.howManyRooms" = "Wie viele Räume kann ich erstellen?";
"faq.howManyRoomsAnswer" = "Sie können bis zu 10 Räume erstellen. Löschen Sie ältere Räume, um Platz für neue zu schaffen. Die Raumanzahl wird oben auf Ihrem Startbildschirm angezeigt.";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "Möbel-Segmentierung";
"faq.whatIsSegmentation" = "Was ist Möbel-Segmentierung?";
"faq.whatIsSegmentationAnswer" = "Die Möbel-Segmentierung verwendet KI, um Möbelstücke in Ihren Fotos zu identifizieren und zu trennen, sodass Sie sehen können, wie jedes Stück in Ihren 3D-Raum passen würde.";
"faq.howToSegment" = "Wie segmentiere ich Möbel aus einem Foto?";
"faq.howToSegmentAnswer" = "Wenn Sie Ihren 3D-Raum betrachten, tippen Sie auf das Möbel-Symbol, um auf die Segmentierungsfunktion zuzugreifen. Wählen Sie ein Foto mit Möbeln aus, und die App erkennt und extrahiert automatisch die Möbelstücke.";
"faq.notDetected" = "Warum werden meine Möbel nicht erkannt?";
"faq.notDetectedAnswer" = "Die Möbelerkennung funktioniert am besten mit klaren, gut beleuchteten Fotos, auf denen die Möbel deutlich sichtbar sind. Stellen Sie sicher, dass die Möbel nicht teilweise verdeckt sind oder mit dem Hintergrund verschmelzen.";
"faq.multiplePieces" = "Kann ich mehrere Möbelstücke segmentieren?";
"faq.multiplePiecesAnswer" = "Ja! Die KI kann mehrere Möbelstücke in einem einzigen Foto erkennen. Jedes erkannte Element wird separat angezeigt, sodass Sie auswählen können, welche Sie verwenden möchten.";

// FAQ - 3D Room & Fitment
"faq.roomFitment" = "3D-Raum & Anpassung";
"faq.howToView" = "Wie betrachte ich meinen 3D-Raum?";
"faq.howToViewAnswer" = "Tippen Sie auf einen beliebigen Raum auf Ihrem Startbildschirm, um den 3D-Viewer zu öffnen. Sie können mit Touch-Gesten drehen, zoomen und schwenken.";
"faq.howToPlace" = "Wie platziere ich Möbel in meinem Raum?";
"faq.howToPlaceAnswer" = "Nach der Segmentierung von Möbeln tippen Sie auf das Möbelstück, um es Ihrem Raum hinzuzufügen. Sie können es dann ziehen, um es zu positionieren, zusammenziehen, um die Größe zu ändern, und drehen, um seine Ausrichtung anzupassen.";
"faq.sampleRoom" = "Kann ich einen Beispielraum anstelle meines eigenen verwenden?";
"faq.sampleRoomAnswer" = "Ja! Die App bietet Beispielräume zum Experimentieren. Greifen Sie über den Entdecken-Bereich darauf zu, um die Möbelplatzierung auszuprobieren, ohne zuerst Ihren eigenen Raum zu erstellen.";
"faq.accuracy" = "Wie genau ist das 3D-Modell?";
"faq.accuracyAnswer" = "Das 3D-Modell bietet eine gute Annäherung an Ihr Raumlayout. Für beste Genauigkeit stellen Sie sicher, dass Ihr Originalfoto die Raummaße deutlich mit sichtbaren Ecken und Kanten erfasst.";
"faq.adjustDimensions" = "Kann ich die Raummaße anpassen?";
"faq.adjustDimensionsAnswer" = "Ja, gehen Sie zu Einstellungen und suchen Sie nach Raummaße-Optionen, wo Sie die Größe und Proportionen Ihres generierten Raums feinabstimmen können.";


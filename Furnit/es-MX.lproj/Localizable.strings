// FAQ - Room Creation
"faq.roomCreation" = "Creación de cuartos";
"faq.howToCreate" = "¿Cómo creo un cuarto 3D?";
"faq.howToCreateAnswer" = "Toca el ícono de foto en la esquina superior izquierda de la pantalla de inicio, luego toma o selecciona una foto de tu cuarto. Verás dos opciones para elegir cómo crear tu cuarto 3D.";
"faq.howToTakePhoto" = "¿Cómo tomo una foto para crear un cuarto?";
"faq.howToTakePhotoAnswer" = "Toca el ícono de cámara en la pantalla de inicio para tomar una foto directamente. Puedes elegir entre lente Estándar (1x) o Gran Angular (0.5x ultra ancho). Mantén tu dispositivo firme y toca el botón de captura. La foto se usará para crear tu cuarto 3D.";
"faq.depthAwareRoomPhoto" = "¿Ayuda tomar la foto en la app?";
"faq.depthAwareRoomPhotoAnswer" = "Sí. En dispositivos compatibles, «Tomar una foto» usa la cámara de la app con profundidad si está disponible, lo que puede mejorar el cuarto 3D.";
"faq.twoMethods" = "¿Cuáles son las dos opciones para crear un cuarto?";
"faq.twoMethodsAnswer" = "Al elegir una foto: 1) Cuarto 3D con IA – crea automáticamente un cuarto realista, o 2) Configuración manual – dibujas los límites tú mismo para más control.";
"faq.whatIsAIRoom" = "¿Qué es el cuarto 3D con IA?";
"faq.whatIsAIRoomAnswer" = "Convierte tu foto automáticamente en un cuarto 3D que puedes recorrer. Elige una foto y la app hace el resto.";
"faq.whatIsManualRoom" = "¿Qué es la configuración manual?";
"faq.whatIsManualRoomAnswer" = "Dibujas el contorno de las paredes en la foto para controlar mejor la forma del cuarto 3D.";
"faq.whichMethodBetter" = "¿Qué método elijo?";
"faq.whichMethodBetterAnswer" = "Prueba primero la IA: es más rápida y suele funcionar bien. Si no convence, usa la configuración manual. ¡Puedes probar ambas!";
"faq.bestPhotos" = "¿Qué tipo de fotos funcionan mejor?";
"faq.bestPhotosAnswer" = "Para mejores resultados, toma fotos con buena iluminación y la cámara en horizontal. Intenta capturar todo el cuarto incluyendo pisos, paredes y bordes del techo. Evita fotos borrosas u oscuras.";
"faq.generationFailing" = "¿Por qué falla la generación de mi cuarto?";
"faq.generationFailingAnswer" = "La generación de cuarto puede fallar si la foto es muy oscura, borrosa o no muestra suficientes características del cuarto. Intenta tomar una nueva foto con mejor iluminación y un ángulo más amplio.";
"faq.howManyRooms" = "¿Cuántos cuartos puedo crear?";
"faq.howManyRoomsAnswer" = "Puedes crear hasta 1000 cuartos. Elimina cuartos viejos para liberar espacio. Arriba verás el número de cuartos y el almacenamiento usado.";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "Segmentación de muebles";
"faq.whatIsSegmentation" = "¿Qué es la segmentación de muebles?";
"faq.whatIsSegmentationAnswer" = "La segmentación de muebles usa IA para identificar y separar muebles en tus fotos, permitiéndote ver cómo cada pieza quedaría en tu cuarto 3D.";
"faq.howToSegment" = "¿Cómo segmento muebles de una foto?";
"faq.howToSegmentAnswer" = "Al ver tu cuarto 3D, toca el icono de muebles para acceder a la función de segmentación. Selecciona una foto con muebles y la app detectará y extraerá automáticamente los elementos de mobiliario.";
"faq.notDetected" = "¿Por qué no se detectan mis muebles?";
"faq.notDetectedAnswer" = "La detección de muebles funciona mejor con fotos claras y bien iluminadas donde los muebles son claramente visibles. Asegúrate de que los muebles no estén parcialmente ocultos o se confundan con el fondo.";
"faq.multiplePieces" = "¿Puedo segmentar múltiples muebles?";
"faq.multiplePiecesAnswer" = "¡Sí! La IA puede detectar múltiples muebles en una sola foto. Cada elemento detectado se mostrará por separado para que puedas elegir cuáles usar.";

// FAQ - 3D Room & Fitment
"faq.roomFitment" = "¿Cómo compruebo si el mueble encaja?";
"faq.roomFitmentAnswer" = "Tras añadir un mueble, redimensiónalo y muévelo en el cuarto 3D para ver cómo encaja con el espacio y otros muebles.";
"faq.howToView" = "¿Cómo veo mi cuarto 3D?";
"faq.howToViewAnswer" = "Toca cualquier cuarto en tu pantalla de inicio para abrir el visor 3D. Puedes rotar, hacer zoom y desplazarte por el cuarto usando gestos táctiles.";
"faq.howToPlace" = "¿Cómo coloco muebles en mi cuarto?";
"faq.howToPlaceAnswer" = "Después de segmentar muebles, toca el mueble para agregarlo a tu cuarto. Luego puedes arrastrarlo para posicionarlo, pellizcar para cambiar el tamaño y rotar para ajustar su orientación.";
"faq.sampleRoom" = "¿Puedo usar un cuarto de ejemplo en lugar del mío?";
"faq.sampleRoomAnswer" = "¡Sí! La app proporciona cuartos de ejemplo para experimentar. Accede a ellos desde la sección Explorar para probar la colocación de muebles sin crear primero tu propio cuarto.";
"faq.accuracy" = "¿Qué tan preciso es el modelo 3D?";
"faq.accuracyAnswer" = "El modelo 3D proporciona una buena aproximación del diseño de tu cuarto. Para mayor precisión, asegúrate de que tu foto original capture claramente las dimensiones del cuarto con esquinas y bordes visibles.";
"faq.adjustDimensions" = "¿Puedo ajustar las dimensiones del cuarto?";
"faq.adjustDimensionsAnswer" = "Sí, ve a Configuración y busca las opciones de Dimensiones de cuarto donde puedes afinar el tamaño y proporciones de tu cuarto generado.";
"faq.furnitureMeasurements" = "Muebles y medidas";
"faq.arAssistedSizing" = "¿Qué es el tamaño de muebles asistido por AR?";
"faq.arAssistedSizingAnswer" = "Si está activado en Configuración, la app combina profundidad de cámara y detección de objetos para escalar la superposición con más realismo al acercarte o alejarte. Mejor con buena luz y el objeto bien visible.";
"faq.measurementPill" = "¿Qué es la pequeña lectura de medidas?";
"faq.measurementPillAnswer" = "Con SmartyPants activo puede mostrarse la altura estimada del mueble y del cuarto. Toca para introducir medidas reales. Si la foto es con gran angular (0,5×), indícalo.";
"faq.resetOverlayScale" = "La máscara se ve mal ampliada — ¿qué hago?";
"faq.resetOverlayScaleAnswer" = "En el cuarto 3D abre el menú (⋮) y elige Restablecer escala de superposición. Quita el zoom automático de la máscara.";


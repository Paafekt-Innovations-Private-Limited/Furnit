// FAQ - Room Creation
"faq.roomCreation" = "कमरा निर्माण";
"faq.howToCreate" = "3D कमरा कैसे बनाएं?";
"faq.howToCreateAnswer" = "होम स्क्रीन के ऊपरी-बाएं कोने में फोटो आइकन टैप करें, फिर अपने कमरे की फोटो लें या चुनें। आपको अपना 3D कमरा बनाने के लिए दो विकल्प दिखाई देंगे।";
"faq.howToTakePhoto" = "कमरा बनाने के लिए फोटो कैसे लें?";
"faq.howToTakePhotoAnswer" = "सीधे फोटो लेने के लिए होम स्क्रीन पर कैमरा आइकन टैप करें। आप स्टैंडर्ड (1x) या वाइड एंगल (0.5x अल्ट्रा-वाइड) लेंस में से चुन सकते हैं। अपने डिवाइस को स्थिर रखें और कैप्चर बटन टैप करें। फोटो का उपयोग आपका 3D कमरा बनाने के लिए किया जाएगा।";
"faq.depthAwareRoomPhoto" = "क्या ऐप में फोटो लेने से कमरे की गुणवत्ता बेहतर होती है?";
"faq.depthAwareRoomPhotoAnswer" = "हाँ। समर्थित डिवाइसों पर गैलरी के बजाय Take a photo इन-ऐप कैमरा और उपलब्ध होने पर गहराई का उपयोग करता है, जिससे 3D कमरा बेहतर बन सकता है।";
"faq.twoMethods" = "कमरा बनाने के दो विकल्प क्या हैं?";
"faq.twoMethodsAnswer" = "फोटो चुनने पर आप चुन सकते हैं: 1) AI-संचालित 3D रूम – AI से अपने आप यथार्थवादी 3D कमरा बनाता है, या 2) मैनुअल सेटअप – आप खुद कमरे की सीमाएं खींचते हैं और ज़्यादा नियंत्रण रखते हैं।";
"faq.whatIsAIRoom" = "AI-संचालित 3D रूम क्या है?";
"faq.whatIsAIRoomAnswer" = "यह विकल्प आपकी फोटो को स्वचालित रूप से 3D रूम में बदलने के लिए स्मार्ट तकनीक का उपयोग करता है जिसमें आप चल सकते हैं। बस एक फोटो चुनें और ऐप बाकी करता है - ड्रॉइंग या एडजस्टमेंट की जरूरत नहीं। जादू की तरह काम करता है!";
"faq.whatIsManualRoom" = "मैनुअल सेटअप क्या है?";
"faq.whatIsManualRoomAnswer" = "मैनुअल सेटअप में आप फोटो पर कमरे की दीवारों का आउटलाइन खींचते हैं। इससे 3D कमरे का लुक आप खुद तय कर सकते हैं। कमरे का आकार खुद ठीक करने के लिए बढ़िया है।";
"faq.whichMethodBetter" = "मुझे कौन सा तरीका चुनना चाहिए?";
"faq.whichMethodBetterAnswer" = "पहले AI वाला आज़माएं – तेज़ है और ज़्यादातर कमरों के लिए अच्छा काम करता है। अगर नतीजा ठीक न लगे तो मैनुअल सेटअप से दीवारें जहाँ चाहें खींचें। दोनों आज़मा सकते हैं!";
"faq.bestPhotos" = "किस तरह की फोटो सबसे अच्छी काम करती हैं?";
"faq.bestPhotosAnswer" = "सर्वोत्तम परिणामों के लिए, अच्छी रोशनी में कैमरा समतल रखकर फोटो लें। फर्श, दीवारों और छत के किनारों सहित पूरे कमरे को कैप्चर करने का प्रयास करें। धुंधली या अंधेरी फोटो से बचें।";
"faq.generationFailing" = "मेरा कमरा जनरेशन क्यों विफल हो रहा है?";
"faq.generationFailingAnswer" = "यदि फोटो बहुत अंधेरी, धुंधली है या पर्याप्त कमरे की विशेषताएं नहीं दिखाती है तो कमरा जनरेशन विफल हो सकता है। बेहतर रोशनी और व्यापक कोण के साथ नई फोटो लेने का प्रयास करें।";
"faq.howManyRooms" = "मैं कितने कमरे बना सकता हूं?";
"faq.howManyRoomsAnswer" = "आप 1000 कमरों तक बना सकते हैं। नए कमरों के लिए जगह बनाने हेतु पुराने हटाएं। कमरों की संख्या और उपयोग किया स्टोरेज होम स्क्रीन के शीर्ष पर दिखता है।";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "फर्नीचर सेगमेंटेशन";
"faq.whatIsSegmentation" = "फर्नीचर सेगमेंटेशन क्या है?";
"faq.whatIsSegmentationAnswer" = "फर्नीचर सेगमेंटेशन AI का उपयोग करके आपकी फोटो में फर्नीचर आइटम की पहचान करता है और उन्हें अलग करता है, जिससे आप देख सकते हैं कि प्रत्येक टुकड़ा आपके 3D कमरे में कैसे फिट होगा।";
"faq.howToSegment" = "फोटो से फर्नीचर कैसे सेगमेंट करें?";
"faq.howToSegmentAnswer" = "अपना 3D कमरा देखते समय, सेगमेंटेशन फीचर एक्सेस करने के लिए फर्नीचर आइकन टैप करें। फर्नीचर वाली फोटो चुनें, और ऐप स्वचालित रूप से फर्नीचर आइटम का पता लगाएगा और निकालेगा।";
"faq.notDetected" = "मेरा फर्नीचर क्यों नहीं पहचाना जा रहा?";
"faq.notDetectedAnswer" = "फर्नीचर पहचान स्पष्ट, अच्छी रोशनी वाली फोटो में सबसे अच्छा काम करती है जहां फर्नीचर स्पष्ट रूप से दिखाई देता है। सुनिश्चित करें कि फर्नीचर आंशिक रूप से छिपा नहीं है या पृष्ठभूमि के साथ मिश्रित नहीं है।";
"faq.multiplePieces" = "क्या मैं एक से अधिक फर्नीचर पीस सेगमेंट कर सकता हूं?";
"faq.multiplePiecesAnswer" = "हां! AI एक ही फोटो में कई फर्नीचर पीस का पता लगा सकता है। प्रत्येक पहचाना गया आइटम अलग से दिखाया जाएगा ताकि आप चुन सकें कि कौन से उपयोग करने हैं।";

// FAQ - 3D Room & Fitment
"faq.howToView" = "अपना 3D कमरा कैसे देखें?";
"faq.howToViewAnswer" = "3D व्यूअर खोलने के लिए अपनी होम स्क्रीन पर किसी भी कमरे पर टैप करें। आप टच जेस्चर का उपयोग करके घुमा सकते हैं, ज़ूम कर सकते हैं और पैन कर सकते हैं।";
"faq.howToPlace" = "अपने कमरे में फर्नीचर कैसे रखें?";
"faq.howToPlaceAnswer" = "फर्नीचर सेगमेंट करने के बाद, इसे अपने कमरे में जोड़ने के लिए फर्नीचर पीस पर टैप करें। फिर आप इसे स्थिति देने के लिए खींच सकते हैं, आकार बदलने के लिए पिंच कर सकते हैं, और इसकी दिशा समायोजित करने के लिए घुमा सकते हैं।";
"faq.sampleRoom" = "क्या मैं अपने बजाय सैंपल रूम उपयोग कर सकता हूं?";
"faq.sampleRoomAnswer" = "हां! ऐप प्रयोग करने के लिए सैंपल रूम प्रदान करता है। पहले अपना कमरा बनाए बिना फर्नीचर प्लेसमेंट आज़माने के लिए एक्सप्लोर सेक्शन से उन्हें एक्सेस करें।";
"faq.accuracy" = "3D मॉडल कितना सटीक है?";
"faq.accuracyAnswer" = "3D मॉडल आपके कमरे के लेआउट का अच्छा अनुमान प्रदान करता है। सर्वोत्तम सटीकता के लिए, सुनिश्चित करें कि आपकी मूल फोटो दृश्यमान कोनों और किनारों के साथ कमरे के आयामों को स्पष्ट रूप से कैप्चर करती है।";
"faq.adjustDimensions" = "क्या मैं कमरे के आयाम समायोजित कर सकता हूं?";
"faq.adjustDimensionsAnswer" = "हां, सेटिंग्स पर जाएं और कमरे के आयाम विकल्प खोजें जहां आप अपने जनरेटेड रूम के आकार और अनुपात को फाइन-ट्यून कर सकते हैं।";
"faq.furnitureMeasurements" = "फर्नीचर और माप";
"faq.arAssistedSizing" = "AR-सहायता वाला फर्नीचर साइज़िंग क्या है?";
"faq.arAssistedSizingAnswer" = "सेटिंग्स में चालू होने पर ऐप कैमरा की गहराई और ऑब्जेक्ट डिटेक्शन मिलाकर जैसे ही आप पास या दूर जाते हैं ओवरले को यथार्थवादी स्केल देता है। अच्छी रोशनी और साफ दृश्य में सबसे अच्छा काम करता है।";
"faq.measurementPill" = "छोटा माप रीडआउट क्या है?";
"faq.measurementPillAnswer" = "SmartyPants चालू होने पर अनुमानित फर्नीचर और कमरे की ऊँचाई दिख सकती है। सटीकता के लिए टैप करके वास्तविक माप दर्ज करें। अगर कमरे की फोटो वाइड-एंगल (0.5×) से ली गई हो तो उसे चिह्नित करें।";
"faq.resetOverlayScale" = "मास्क गलत ज़ूम लग रहा है—क्या करें?";
"faq.resetOverlayScaleAnswer" = "3D कमरे में ओवरफ़्लो मेनू (⋮) खोलकर Reset overlay scale चुनें। डिटेक्शन मास्क पर लगा ऑटो ज़ूम हट जाएगा।";
"faq.roomFitment" = "फर्नीचर फिट है या नहीं कैसे जांचें?";
"faq.roomFitmentAnswer" = "फर्नीचर जोड़ने के बाद अपने 3D कमरे में इसका आकार बदलकर और स्थान बदलकर देखें कि यह आपकी जगह और अन्य फर्नीचर के साथ कैसा बैठता है।";


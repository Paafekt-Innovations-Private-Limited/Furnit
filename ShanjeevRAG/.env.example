# Copy to .env and fill in if needed.
# For basic RAG (ingest + retrieval), no keys are required; embeddings run locally.

# Optional: OpenAI for answer generation (query.py --llm openai)
# OPENAI_API_KEY=sk-...

# Optional: Perplexity for answer generation (query.py --llm perplexity); uses RAG context only (web search disabled)
# PERPLEXITY_API_KEY=pplx-...

# Optional: override paths (defaults: data/, vector_db/)
# RAG_DATA_DIR=data
# RAG_VECTOR_DB_PATH=vector_db

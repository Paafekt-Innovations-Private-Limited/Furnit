platform :ios, '15.0'

target 'Furnit' do
  use_frameworks!

  # ONNX Runtime for Objective-C (CPU/CoreML) – used only by the new blue icon path.
  # After adding this Podfile, run:
  #   cd Furnit
  #   pod install
  # Then open Furnit.xcworkspace instead of Furnit.xcodeproj.
  pod 'onnxruntime-objc'
end


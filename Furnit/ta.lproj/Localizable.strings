// FAQ - Room Creation
"faq.roomCreation" = "அறை உருவாக்கம்";
"faq.howToCreate" = "3D அறையை எப்படி உருவாக்குவது?";
"faq.howToCreateAnswer" = "முகப்பு திரையின் மேல்-இடது மூலையில் உள்ள புகைப்பட ஐகானைத் தட்டவும், பின்னர் உங்கள் அறையின் புகைப்படம் எடுக்கவும் அல்லது தேர்ந்தெடுக்கவும். உங்கள் 3D அறையை உருவாக்க இரண்டு விருப்பங்களைக் காண்பீர்கள்.";
"faq.howToTakePhoto" = "அறை உருவாக்க புகைப்படம் எப்படி எடுப்பது?";
"faq.howToTakePhotoAnswer" = "நேரடியாக புகைப்படம் எடுக்க முகப்பு திரையில் கேமரா ஐகானைத் தட்டவும். நிலையான (1x) அல்லது அகலக்கோண (0.5x அல்ட்ரா-வைட்) லென்ஸைத் தேர்வு செய்யலாம். உங்கள் சாதனத்தை நிலையாகப் பிடித்து, படப்பிடிப்பு பொத்தானைத் தட்டவும். புகைப்படம் உங்கள் 3D அறையை உருவாக்க பயன்படுத்தப்படும்.";
"faq.twoMethods" = "What are the two room creation options?";
"faq.twoMethodsAnswer" = "When you select a photo, you can choose between: 1) AI-Powered 3D Room - automatically creates a realistic 3D room using artificial intelligence, or 2) Manual Setup - lets you draw the room boundaries yourself for more control.";
"faq.whatIsAIRoom" = "What is AI-Powered 3D Room?";
"faq.whatIsAIRoomAnswer" = "This option uses smart technology to automatically turn your photo into a 3D room you can walk through. Just pick a photo and the app does the rest - no drawing or adjusting needed. It works like magic!";
"faq.whatIsManualRoom" = "What is Manual Setup?";
"faq.whatIsManualRoomAnswer" = "With Manual Setup, you draw the outline of your room's walls on the photo. This gives you more control over exactly how the 3D room looks. It's great when you want to fine-tune the room shape yourself.";
"faq.whichMethodBetter" = "Which method should I choose?";
"faq.whichMethodBetterAnswer" = "Try AI-Powered first - it's faster and works great for most rooms. If the result doesn't look quite right, use Manual Setup to draw the walls exactly where you want them. You can always try both and see which one you prefer!";
"faq.bestPhotos" = "எந்த வகையான புகைப்படங்கள் சிறப்பாக செயல்படும்?";
"faq.bestPhotosAnswer" = "சிறந்த முடிவுகளுக்கு, நல்ல வெளிச்சத்தில் சாதனத்தை நிலையாக வைத்து புகைப்படங்கள் எடுக்கவும். தரைகள், சுவர்கள் மற்றும் கூரை விளிம்புகள் உட்பட முழு அறையையும் படம்பிடிக்க முயற்சிக்கவும். மங்கலான அல்லது இருண்ட புகைப்படங்களைத் தவிர்க்கவும்.";
"faq.generationFailing" = "என் அறை உருவாக்கம் ஏன் தோல்வியடைகிறது?";
"faq.generationFailingAnswer" = "புகைப்படம் மிகவும் இருட்டாகவோ, மங்கலாகவோ, அல்லது போதுமான அறை அம்சங்களைக் காட்டவில்லை என்றால் அறை உருவாக்கம் தோல்வியடையலாம். சிறந்த வெளிச்சம் மற்றும் அகலமான கோணத்துடன் புதிய புகைப்படம் எடுக்க முயற்சிக்கவும்.";
"faq.howManyRooms" = "எத்தனை அறைகளை உருவாக்க முடியும்?";
"faq.howManyRoomsAnswer" = "நீங்கள் 10 அறைகள் வரை உருவாக்கலாம். இடம் உருவாக்க பழைய அறைகளை நீக்கவும். அறை எண்ணிக்கை உங்கள் முகப்பு திரையின் மேலே காட்டப்படும்.";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "தளபாட பிரிப்பு";
"faq.whatIsSegmentation" = "தளபாட பிரிப்பு என்றால் என்ன?";
"faq.whatIsSegmentationAnswer" = "தளபாட பிரிப்பு AI ஐப் பயன்படுத்தி உங்கள் புகைப்படங்களில் தளபாடங்களை அடையாளம் கண்டு பிரிக்கிறது, ஒவ்வொரு பொருளும் உங்கள் 3D அறையில் எப்படி பொருந்தும் என்பதைக் காண அனுமதிக்கிறது.";
"faq.howToSegment" = "புகைப்படத்திலிருந்து தளபாடங்களை எப்படி பிரிப்பது?";
"faq.howToSegmentAnswer" = "உங்கள் 3D அறையைப் பார்க்கும்போது, பிரிப்பு அம்சத்தை அணுக தளபாட ஐகானைத் தட்டவும். தளபாடங்கள் உள்ள புகைப்படத்தைத் தேர்ந்தெடுக்கவும், பயன்பாடு தானாகவே தளபாட பொருட்களைக் கண்டறிந்து பிரிக்கும்.";
"faq.notDetected" = "என் தளபாடங்கள் ஏன் கண்டறியப்படவில்லை?";
"faq.notDetectedAnswer" = "தளபாட கண்டறிதல் தெளிவான, நல்ல வெளிச்சமுள்ள புகைப்படங்களில் தளபாடங்கள் தெளிவாகத் தெரியும்போது சிறப்பாக செயல்படுகிறது. தளபாடங்கள் பகுதியளவு மறைக்கப்படவில்லை அல்லது பின்னணியுடன் கலக்கவில்லை என்பதை உறுதிப்படுத்தவும்.";
"faq.multiplePieces" = "பல தளபாடங்களை பிரிக்க முடியுமா?";
"faq.multiplePiecesAnswer" = "ஆம்! AI ஒரு புகைப்படத்தில் பல தளபாடங்களைக் கண்டறிய முடியும். கண்டறியப்பட்ட ஒவ்வொரு பொருளும் தனித்தனியாகக் காட்டப்படும், எதைப் பயன்படுத்த வேண்டும் என்பதை நீங்கள் தேர்வு செய்யலாம்.";

// FAQ - 3D Room & Fitment
"faq.roomFitment" = "3D அறை & பொருத்தம்";
"faq.howToView" = "என் 3D அறையை எப்படி பார்ப்பது?";
"faq.howToViewAnswer" = "3D பார்வையாளரைத் திறக்க முகப்பு திரையில் எந்த அறையையும் தட்டவும். தொடு சைகைகளைப் பயன்படுத்தி அறையை சுழற்றலாம், பெரிதாக்கலாம் மற்றும் நகர்த்தலாம்.";
"faq.howToPlace" = "என் அறையில் தளபாடங்களை எப்படி வைப்பது?";
"faq.howToPlaceAnswer" = "தளபாடங்களைப் பிரித்த பிறகு, உங்கள் அறையில் சேர்க்க ஒரு பொருளைத் தட்டவும். நிலைநிறுத்த இழுக்கலாம், அளவை மாற்ற பிஞ்ச் செய்யலாம், திசையை சரிசெய்ய சுழற்றலாம்.";
"faq.sampleRoom" = "என்னுடையதற்கு பதிலாக மாதிரி அறையைப் பயன்படுத்த முடியுமா?";
"faq.sampleRoomAnswer" = "ஆம்! பயன்பாடு பரிசோதிக்க மாதிரி அறைகளை வழங்குகிறது. முதலில் உங்கள் சொந்த அறையை உருவாக்காமல் தளபாட வைப்பை முயற்சிக்க ஆராய் பிரிவிலிருந்து அவற்றை அணுகவும்.";
"faq.accuracy" = "3D மாதிரி எவ்வளவு துல்லியமானது?";
"faq.accuracyAnswer" = "3D மாதிரி உங்கள் அறை அமைப்பின் நல்ல தோராயத்தை வழங்குகிறது. சிறந்த துல்லியத்திற்கு, உங்கள் அசல் புகைப்படம் தெரியும் மூலைகள் மற்றும் விளிம்புகளுடன் அறை பரிமாணங்களை தெளிவாகப் படம்பிடிக்கிறது என்பதை உறுதிப்படுத்தவும்.";
"faq.adjustDimensions" = "அறை பரிமாணங்களை சரிசெய்ய முடியுமா?";
"faq.adjustDimensionsAnswer" = "ஆம், அமைப்புகளுக்குச் சென்று அறை பரிமாண விருப்பங்களைக் கண்டறியவும், அங்கு உருவாக்கப்பட்ட அறையின் அளவு மற்றும் விகிதாச்சாரங்களை நுணுக்கமாக சரிசெய்யலாம்.";


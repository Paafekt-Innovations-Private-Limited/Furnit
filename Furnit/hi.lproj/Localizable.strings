// FAQ - AI Features (added)
"faq.aiFeatures" = "AI सुविधाएं";
"faq.whatIsBrainIcon" = "ब्रेन आइकन क्या करता है?";
"faq.whatIsBrainIconAnswer" = "ब्रेन आइकन SmartyPants identify mode शुरू करता है। यह लाइव कैमरा से फर्नीचर और वस्तुओं को ढूँढता है, लेबल और बॉक्स दिखाता है, और Segment टैप करने से पहले आपको एक या अधिक लेबल चुनने देता है।";
"faq.howToScreenshot" = "स्क्रीनशॉट कैसे लें?";
"faq.howToScreenshotAnswer" = "जब SmartyPants सक्रिय हो (ब्रेन आइकन हरा), नीचे-दाईं ओर एक शेयर आइकन दिखाई देता है। AI डिटेक्शन के साथ व्यू का स्क्रीनशॉट अपनी फोटो लाइब्रेरी में सेव करने के लिए इसे टैप करें।";
"faq.howToSaveRoom" = "रूम कैसे सेव करें?";
"faq.howToSaveRoomAnswer" = "3D रूम जनरेट करने के बाद, कस्टम नाम के साथ सेव करने के लिए टूलबार में सेव आइकन (डाउनलोड एरो) पर टैप करें। सेव न किए गए रूम बैक टैप करने पर डिलीट हो जाएंगे।";

// FAQ - 3D Room Controls (added)
"faq.roomControls" = "3D रूम नियंत्रण";
"faq.howToNavigate" = "रूम के अंदर कैसे नेविगेट करें?";
"faq.howToNavigateAnswer" = "स्क्रीन के नीचे बीच में जॉयस्टिक का उपयोग करें। रूम में उड़ने के लिए किसी भी दिशा में खींचें। कैमरा पोजीशन रीसेट करने के लिए रीसेंटर बटन (व्यूफाइंडर आइकन) पर टैप करें।";
"faq.whatDoArrowsDo" = "तीर बटन क्या करते हैं?";
"faq.whatDoArrowsDoAnswer" = "3D व्यू के किनारे के तीर बटन कैमरा हिलाते हैं: ऊपर-नीचे दृश्य की ऊंचाई बदलते हैं; बाएं-दाएं कैमरा पैन करते हैं। आप स्क्रीन पर खींचकर रूम ऑर्बिट भी कर सकते हैं और दृश्य रीसेट करने के लिए रीसेंटर बटन (व्यूफाइंडर आइकन) इस्तेमाल कर सकते हैं।";
"faq.whatIsMemoryDisplay" = "MB नंबर का क्या मतलब है?";
"faq.whatIsMemoryDisplayAnswer" = "रूम में दिखाया गया MB (मेगाबाइट्स) फाइल साइज इंगित करता है। यह आपको स्टोरेज मैनेज करने में मदद करता है। सभी रूम द्वारा उपयोग किया गया कुल स्टोरेज होम स्क्रीन के शीर्ष पर दिखाया जाता है।";


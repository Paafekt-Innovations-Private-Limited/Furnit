<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sharp_inference_running"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/sharp_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:max="100"
        android:progress="0"
        android:indeterminate="false"
        app:trackThickness="10dp"
        app:trackCornerRadius="5dp"
        app:indicatorColor="@color/sharp_ai_progress_indicator"
        app:trackColor="@color/sharp_ai_progress_track" />

    <TextView
        android:id="@+id/sharp_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sharp_inference_preparing"
        android:textSize="14sp" />
</LinearLayout>

// FAQ - AI Features (added)
"faq.aiFeatures" = "Funciones de IA";
"faq.whatIsBrainIcon" = "¿Qué hace el ícono del cerebro?";
"faq.whatIsBrainIconAnswer" = "El ícono del cerebro inicia el modo de identificación de SmartyPants. Usa la cámara en vivo para encontrar muebles y objetos, muestra etiquetas y recuadros, y te permite seleccionar una o más etiquetas antes de tocar Segmentar.";
"faq.howToScreenshot" = "¿Cómo tomo una captura de pantalla?";
"faq.howToScreenshotAnswer" = "Cuando SmartyPants está activo (ícono del cerebro verde), aparece un ícono de compartir en la parte inferior derecha. Tócalo para guardar una captura de pantalla con las detecciones de IA en tu biblioteca de fotos.";
"faq.howToSaveRoom" = "¿Cómo guardo un cuarto?";
"faq.howToSaveRoomAnswer" = "Después de generar un cuarto 3D, toca el ícono de guardar (flecha de descarga) en la barra de herramientas para guardarlo con un nombre personalizado. Los cuartos no guardados se eliminarán al tocar Atrás.";

// FAQ - 3D Room Controls (added)
"faq.roomControls" = "Controles de Cuarto 3D";
"faq.howToNavigate" = "¿Cómo navego dentro del cuarto?";
"faq.howToNavigateAnswer" = "Usa el joystick en la parte inferior central de la pantalla para moverte. Arrástralo en cualquier dirección para volar por el cuarto. Usa el botón de recentrar (ícono del visor) para restablecer la posición de la cámara.";
"faq.whatDoArrowsDo" = "¿Qué hacen los botones de flechas?";
"faq.whatDoArrowsDoAnswer" = "Los botones de flechas al lado de la vista 3D mueven la cámara: arriba y abajo cambian la altura de la vista; izquierda y derecha hacen paneo. También puedes arrastrar en la pantalla para orbitar el cuarto y usar el botón de recentrar (ícono del visor) para restablecer la vista.";
"faq.whatIsMemoryDisplay" = "¿Qué significa el número MB?";
"faq.whatIsMemoryDisplayAnswer" = "El MB (megabytes) mostrado en los cuartos indica el tamaño del archivo. Esto te ayuda a administrar el almacenamiento. El almacenamiento total usado por todos los cuartos se muestra en la parte superior de la pantalla de inicio.";


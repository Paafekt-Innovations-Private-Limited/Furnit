# SAP WebGUI URL for browser automation
SAP_WEBGUI_URL=https://your-sap-system:8000/sap/bc/gui/sap/its/webgui

# SAP login credentials
SAP_USER=your_sap_user
SAP_PASS=your_sap_password

# Claude API key (optional - for LLM code generation)
ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud project (optional - for Vertex AI fine-tuning)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ChromaDB location (default: ./data/vector_db)
VECTOR_DB_PATH=./data/vector_db

# SentenceTransformer model (default: all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2

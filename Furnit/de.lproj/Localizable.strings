// FAQ - Room Creation
"faq.roomCreation" = "Raumerstellung";
"faq.howToCreate" = "Wie erstelle ich einen 3D-Raum?";
"faq.howToCreateAnswer" = "Tippen Sie auf das Foto-Symbol in der oberen linken Ecke des Startbildschirms und nehmen Sie dann ein Foto Ihres Raums auf oder wählen Sie eines aus. Sie sehen zwei Optionen zur Auswahl für die Erstellung Ihres 3D-Raums.";
"faq.howToTakePhoto" = "Wie nehme ich ein Foto auf, um einen Raum zu erstellen?";
"faq.howToTakePhotoAnswer" = "Tippen Sie auf das Kamera-Symbol auf dem Startbildschirm, um direkt ein Foto aufzunehmen. Sie können zwischen Standard (1x) oder Weitwinkel (0.5x Ultra-Weitwinkel) Objektiv wählen. Halten Sie Ihr Gerät ruhig und tippen Sie auf die Aufnahmetaste. Das Foto wird dann verwendet, um Ihren 3D-Raum zu erstellen.";
"faq.depthAwareRoomPhoto" = "Hilft ein Foto in der App der Raumqualität?";
"faq.depthAwareRoomPhotoAnswer" = "Ja. Auf unterstützten Geräten nutzt „Foto aufnehmen“ (statt Galerie) die In-App-Kamera mit Tiefendaten, sofern verfügbar – das kann Aufbau und Maßstab des 3D-Raums verbessern.";
"faq.twoMethods" = "Was sind die beiden Optionen zur Raumerstellung?";
"faq.twoMethodsAnswer" = "Nach der Fotowahl können Sie wählen: 1) KI-gestützter 3D-Raum – erstellt automatisch einen realistischen 3D-Raum, oder 2) Manuelle Einrichtung – Sie zeichnen die Raumgrenzen selbst für mehr Kontrolle.";
"faq.whatIsAIRoom" = "Was ist der KI-gestützte 3D-Raum?";
"faq.whatIsAIRoomAnswer" = "Diese Option verwendet intelligente Technologie, um Ihr Foto automatisch in einen begehbaren 3D-Raum zu verwandeln. Wählen Sie ein Foto – der Rest geht von selbst.";
"faq.whatIsManualRoom" = "Was ist die manuelle Einrichtung?";
"faq.whatIsManualRoomAnswer" = "Bei der manuellen Einrichtung zeichnen Sie den Umriss der Wände auf dem Foto. So haben Sie mehr Kontrolle über die Form des 3D-Raums.";
"faq.whichMethodBetter" = "Welche Methode soll ich wählen?";
"faq.whichMethodBetterAnswer" = "Probieren Sie zuerst die KI-Option – sie ist schneller und passt für die meisten Räume. Passt das Ergebnis nicht, nutzen Sie die manuelle Einrichtung. Sie können beides ausprobieren!";
"faq.bestPhotos" = "Welche Art von Fotos funktionieren am besten?";
"faq.bestPhotosAnswer" = "Für beste Ergebnisse machen Sie Fotos bei guter Beleuchtung mit waagerecht gehaltener Kamera. Versuchen Sie, den gesamten Raum einschließlich Böden, Wänden und Deckenkanten zu erfassen. Vermeiden Sie unscharfe oder dunkle Fotos.";
"faq.generationFailing" = "Warum schlägt meine Raumerstellung fehl?";
"faq.generationFailingAnswer" = "Die Raumerstellung kann fehlschlagen, wenn das Foto zu dunkel, unscharf ist oder nicht genügend Raummerkmale zeigt. Versuchen Sie, ein neues Foto mit besserer Beleuchtung und einem weiteren Winkel aufzunehmen.";
"faq.howManyRooms" = "Wie viele Räume kann ich erstellen?";
"faq.howManyRoomsAnswer" = "Sie können bis zu 1000 Räume erstellen. Löschen Sie ältere Räume, um Platz zu schaffen. Oben auf dem Startbildschirm sehen Sie die Raumanzahl und den belegten Speicher.";

// FAQ - Furniture Segmentation
"faq.furnitureSegmentation" = "Möbel-Segmentierung";
"faq.whatIsSegmentation" = "Was ist Möbel-Segmentierung?";
"faq.whatIsSegmentationAnswer" = "Die Möbel-Segmentierung verwendet KI, um Möbelstücke in Ihren Fotos zu identifizieren und zu trennen, sodass Sie sehen können, wie jedes Stück in Ihren 3D-Raum passen würde.";
"faq.howToSegment" = "Wie segmentiere ich Möbel aus einem Foto?";
"faq.howToSegmentAnswer" = "Wenn Sie Ihren 3D-Raum betrachten, tippen Sie auf das Möbel-Symbol, um auf die Segmentierungsfunktion zuzugreifen. Wählen Sie ein Foto mit Möbeln aus, und die App erkennt und extrahiert automatisch die Möbelstücke.";
"faq.notDetected" = "Warum werden meine Möbel nicht erkannt?";
"faq.notDetectedAnswer" = "Die Möbelerkennung funktioniert am besten mit klaren, gut beleuchteten Fotos, auf denen die Möbel deutlich sichtbar sind. Stellen Sie sicher, dass die Möbel nicht teilweise verdeckt sind oder mit dem Hintergrund verschmelzen.";
"faq.multiplePieces" = "Kann ich mehrere Möbelstücke segmentieren?";
"faq.multiplePiecesAnswer" = "Ja! Die KI kann mehrere Möbelstücke in einem einzigen Foto erkennen. Jedes erkannte Element wird separat angezeigt, sodass Sie auswählen können, welche Sie verwenden möchten.";

// FAQ - 3D Room & Fitment
"faq.roomFitment" = "Wie prüfe ich, ob Möbel passen?";
"faq.roomFitmentAnswer" = "Nach dem Hinzufügen können Sie Möbel im 3D-Raum skalieren und verschieben und so sehen, wie sie zu Raum und anderen Möbeln passen.";

// FAQ - Placement intelligence & aesthetic
"faq.placementIntelligence" = "Platzierung & Ästhetik";
"faq.whatIsPlacementIntelligence" = "Was ist „Placement Intelligence“?";
"faq.whatIsPlacementIntelligenceAnswer" = "Wenn SmartyPants in unterstützten 3D-Raumansichten aktiv ist, fasst eine Karte „Placement Intelligence“ zusammen, ob die erkannte Objektgröße in Ihre Raumgrenzen passt, zeigt bei Bedarf Boden- und Eckvorschläge und weist darauf hin, wenn die Tiefe geschätzt ist. Tippen Sie auf die Kopfzeile für alle Details oder lassen Sie die Karte eingeklappt, um Platz zu sparen.";
"faq.furnitureColorAesthetic" = "Wie wählt die App eine Farbe für die Ästhetikbewertung?";
"faq.furnitureColorAestheticAnswer" = "Die App mittelt die RGB-Farbe der sichtbaren Pixel in der KI-Möbelauswahl (demselben segmentierten Overlay). Diese mittlere Farbe wird mit Farben verglichen, die aus Boden, Wänden und Decke Ihres Raums gesampelt wurden. Ist die Auswahl noch nicht bereit, nutzt die App vorerst eine Farbe aus der Raumpalette, bis die Segmentierung echte Pixel liefert.";
"faq.whatDoHarmonyContrastMean" = "Was bedeuten Harmonie, Kontrast und Stil-Treffer?";
"faq.whatDoHarmonyContrastMeanAnswer" = "Das sind einfache Design-Heuristiken, kein Geschmacksurteil. Harmonie beschreibt, wie sich die Möbelfarbe zur Raumpalette verhält (z. B. analogue oder komplementäre Töne). Kontrast ist, wie unterschiedlich die Helligkeit zu typischen Boden- oder Wandfarben ist. Stil-Treffer vergleicht grobe Stil-Labels des Raums mit einem standardmäßig modernen Profil und ist daher nur annähernd.";
"faq.whenDoesAestheticScoreLow" = "Wann können ästhetische Werte niedrig sein oder „clash“ zeigen?";
"faq.whenDoesAestheticScoreLowAnswer" = "Leuchtend gesättigte Objekte fallen oft schlechter aus, wenn ihr Farbton nicht zu den harmonischen Mustern der App gegenüber Ihrem Raum passt – z. B. giftgrün, Magenta, Violett oder signalorange in warmen Beige- oder Braunräumen, oder grell Primär in einem Raum mit überwiegender Farbfamilie. Sehr ähnliche Helligkeit zu Boden oder Wand (Braun auf Braun, Grau auf Grau) kann den Kontrast senken. Als rustikal oder traditionell erkannte Räume können einen niedrigeren Stil-Treffer zeigen, weil das Möbelprofil standardmäßig moderne/minimalistische Stichwörter nutzt. Matter Grau- oder Schmutzmittel aus unruhigem Hintergrund kann neutral statt clash wirken. Die Werte sind nur Orientierung – beim echten Einrichten zählt Ihr Urteil.";
"faq.howToView" = "Wie betrachte ich meinen 3D-Raum?";
"faq.howToViewAnswer" = "Tippen Sie auf einen beliebigen Raum auf Ihrem Startbildschirm, um den 3D-Viewer zu öffnen. Sie können mit Touch-Gesten drehen, zoomen und schwenken.";
"faq.howToPlace" = "Wie platziere ich Möbel in meinem Raum?";
"faq.howToPlaceAnswer" = "Nach der Segmentierung von Möbeln tippen Sie auf das Möbelstück, um es Ihrem Raum hinzuzufügen. Sie können es dann ziehen, um es zu positionieren, zusammenziehen, um die Größe zu ändern, und drehen, um seine Ausrichtung anzupassen.";
"faq.sampleRoom" = "Kann ich einen Beispielraum anstelle meines eigenen verwenden?";
"faq.sampleRoomAnswer" = "Ja! Die App bietet Beispielräume zum Experimentieren. Greifen Sie über den Entdecken-Bereich darauf zu, um die Möbelplatzierung auszuprobieren, ohne zuerst Ihren eigenen Raum zu erstellen.";
"faq.accuracy" = "Wie genau ist das 3D-Modell?";
"faq.accuracyAnswer" = "Das 3D-Modell bietet eine gute Annäherung an Ihr Raumlayout. Für beste Genauigkeit stellen Sie sicher, dass Ihr Originalfoto die Raummaße deutlich mit sichtbaren Ecken und Kanten erfasst.";
"faq.adjustDimensions" = "Kann ich die Raummaße anpassen?";
"faq.adjustDimensionsAnswer" = "Ja, gehen Sie zu Einstellungen und suchen Sie nach Raummaße-Optionen, wo Sie die Größe und Proportionen Ihres generierten Raums feinabstimmen können.";
"faq.furnitureMeasurements" = "Möbel & Maße";
"faq.arAssistedSizing" = "Was ist AR-gestützte Möbelgröße?";
"faq.arAssistedSizingAnswer" = "Wenn diese Option in den Einstellungen aktiviert ist, kombiniert die App Tiefendaten mit Objekterkennung, damit sich die Möbel-Overlay-Skala beim Näherkommen oder Weggehen realistischer anpasst. Am besten bei guter Beleuchtung und klar sichtbarem Objekt.";
"faq.measurementPill" = "Was bedeutet die kleine Maßanzeige?";
"faq.measurementPillAnswer" = "Während SmartyPants aktiv ist, kann eine kleine Anzeige geschätzte Möbel- und Raumhöhe zeigen. Tippen Sie darauf, um reale Maße einzugeben. War das Raumfoto mit Weitwinkel (0,5×) aufgenommen, markieren Sie das.";
"faq.resetOverlayScale" = "Die Maske wirkt falsch gezoomt – was tun?";
"faq.resetOverlayScaleAnswer" = "Öffnen Sie im 3D-Raum das Überlaufmenü (⋮) und wählen Sie „Overlay-Zoom zurücksetzen“. Damit wird die automatische Skalierung der Erkennungsmaske gelöscht.";

// FAQ - 3D Room Controls
"faq.roomControls" = "3D-Raum-Steuerung";
"faq.howToNavigate" = "Wie bewege ich mich im Raum?";
"faq.howToNavigateAnswer" = "Nutzen Sie den Joystick unten in der Bildschirmmitte zur Bewegung. Ziehen Sie ihn in eine beliebige Richtung, um durch den Raum zu fliegen. Mit der Schaltfläche „Zentrieren“ (Sucher-Symbol) setzen Sie die Kameraposition zurück.";
"faq.whatDoArrowsDo" = "Wofür sind die Pfeiltasten?";
"faq.whatDoArrowsDoAnswer" = "Die Pfeiltasten an der Seite der 3D-Ansicht bewegen die Kamera: oben und unten ändern die Blickhöhe; links und rechts schwenken die Kamera. Sie können auch auf dem Bildschirm ziehen, um den Raum zu umkreisen, und die Zentrieren-Taste (Sucher-Symbol) nutzen, um die Ansicht zurückzusetzen.";
"faq.whatIsMemoryDisplay" = "Was bedeutet die MB-Zahl?";
"faq.whatIsMemoryDisplayAnswer" = "Die in Räumen angezeigte MB (Megabyte) gibt die Dateigröße an. So verwalten Sie den Speicher. Der von allen Räumen genutzte Speicher wird oben auf dem Startbildschirm angezeigt.";


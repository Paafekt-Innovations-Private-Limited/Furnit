// FAQ - Room Creation
"faq.roomCreation" = "রুম তৈরি";
"faq.howToCreate" = "কিভাবে 3D রুম তৈরি করবেন?";
"faq.howToCreateAnswer" = "হোম স্ক্রিনের উপরের-বামে ফোটো আইকনে ট্যাপ করুন, তারপর আপনার রুমের ছবি তুলুন বা সিলেক্ট করুন। আপনার 3D রুম তৈরির জন্য দুটি বিকল্প দেখতে পাবেন।";
